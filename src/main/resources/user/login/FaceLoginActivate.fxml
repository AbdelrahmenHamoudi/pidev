<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<!--
    FaceLoginActivate.fxml
    Used for BOTH login and enroll modes.
    The controller (FaceLoginController) switches behaviour based on
    which mode was set before the stage was shown.
-->
<BorderPane prefHeight="560" prefWidth="700"
            stylesheets="@login.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controllers.user.FaceLoginController">

    <center>
        <StackPane styleClass="form-tunisia-wrapper">
            <Region styleClass="form-bg-orange" />
            <Region styleClass="form-bg-turquoise" />

            <VBox alignment="CENTER" maxWidth="420" spacing="18" styleClass="tunisia-card">

                <!-- Title block -->
                <VBox alignment="CENTER" spacing="8">
                    <StackPane styleClass="tunisia-welcome-icon">
                        <Circle radius="32" styleClass="tunisia-welcome-circle" />
                        <Circle radius="28" styleClass="tunisia-welcome-circle-inner" />
                        <Label styleClass="tunisia-welcome-emoji" text="📷" />
                    </StackPane>
                    <VBox alignment="CENTER" spacing="2">
                        <Label styleClass="tunisia-welcome-title" text="Face ID" />
                        <Label styleClass="tunisia-form-title" text="Connexion / Enregistrement" />
                    </VBox>
                    <Region styleClass="tunisia-title-decoration" />
                </VBox>

                <!-- Live camera feed -->
                <ImageView fx:id="cameraView"
                           fitWidth="420" fitHeight="320"
                           preserveRatio="true"
                           style="-fx-border-color: rgba(26,188,156,0.35);
                                  -fx-border-width: 2;
                                  -fx-background-radius: 20;
                                  -fx-border-radius: 20;" />

                <!-- Action button  -->
                <HBox spacing="10" alignment="CENTER">
                    <!--
                        onCaptureFace is the unified action:
                        • LOGIN mode  → calls faceIdService.loginWithFace()
                        • ENROLL mode → calls faceIdService.registerFace()
                    -->
                    <Button fx:id="captureBtn"
                            text="LOGIN"
                            onAction="#onCaptureFace"
                            prefHeight="50" prefWidth="180"
                            styleClass="tunisia-login-btn" />
                </HBox>

                <!-- Status / feedback label -->
                <Label fx:id="statusLabel"
                       styleClass="tunisia-signup-text"
                       text="Status..."
                       wrapText="true"
                       maxWidth="380" />

            </VBox>
        </StackPane>
    </center>

</BorderPane>
