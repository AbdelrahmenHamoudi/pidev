<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane prefHeight="700.0" prefWidth="1100.0" stylesheets="@users.css"
            xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controllers.user.admin.AdminNotificationsController">

    <top>
        <VBox styleClass="nav-container">
            <HBox alignment="CENTER_LEFT" spacing="30" styleClass="nav-bar">
                <padding>
                    <Insets top="15" right="40" bottom="15" left="40" />
                </padding>

                <HBox alignment="CENTER" spacing="12" styleClass="nav-logo">
                    <StackPane styleClass="nav-logo-bg">
                        <Circle radius="25" styleClass="nav-logo-circle" />
                        <ImageView fitHeight="35" fitWidth="35">
                            <Image url="@../image/logo.png" />
                        </ImageView>
                    </StackPane>
                    <Label styleClass="nav-logo-text" text="RE7LA Admin" />
                </HBox>

                <Label styleClass="page-title" text="Notifications système" />

                <Region HBox.hgrow="ALWAYS" />

                <HBox spacing="10">
                    <Button styleClass="secondary-button" text="Tout marquer comme lu" onAction="#markAllAsRead" />
                    <Button styleClass="btn-home" text="← Retour" onAction="#handleBack" />
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="main-scroll-pane">
            <VBox spacing="25" styleClass="content-area">
                <padding>
                    <Insets top="30" right="30" bottom="30" left="30" />
                </padding>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label styleClass="section-title" text="🔔 Centre de notifications" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="unreadCountLabel" styleClass="stat-value-small" text="0 non lues" />
                </HBox>

                <ListView fx:id="notificationsList" prefHeight="500" VBox.vgrow="ALWAYS" />
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>