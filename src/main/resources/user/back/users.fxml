<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0" stylesheets="@users.css"
            xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controllers.user.admin.user.AdminUsersController">

    <!-- SIDEBAR -->
    <VBox fx:id="sidebar" prefWidth="260.0" spacing="10.0" styleClass="sidebar"
          AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">

        <VBox alignment="CENTER" spacing="15.0">
            <VBox.margin>
                <Insets top="25.0" />
            </VBox.margin>

            <!-- Logo -->
            <ImageView fitHeight="150.0" fitWidth="150.0" preserveRatio="true">
                <image>
                    <Image url="@../image/logo.png" />
                </image>
            </ImageView>
        </VBox>

        <Label styleClass="sidebar-title" text="Tableau de bord">
            <VBox.margin>
                <Insets bottom="30.0" left="25.0" />
            </VBox.margin>
        </Label>

        <Button fx:id="btnGestionUtilisateurs" alignment="BASELINE_LEFT" maxWidth="Infinity"
                mnemonicParsing="false" onAction="#handleShowUsers" styleClass="sidebar-button-active"
                text="👥   Gestion Utilisateurs" />
        <Button fx:id="btnComptesBancaires" alignment="BASELINE_LEFT" maxWidth="Infinity"
                mnemonicParsing="false" onAction="#handleShowAccounts" styleClass="sidebar-button"
                text="💳   Gestion des Hébergements" />
        <Button fx:id="btnTransactions" alignment="BASELINE_LEFT" maxWidth="Infinity"
                mnemonicParsing="false" onAction="#handleShowTransactions" styleClass="sidebar-button"
                text="💸   Gestion des Activités" />
        <Button fx:id="btnCredits" alignment="BASELINE_LEFT" maxWidth="Infinity"
                mnemonicParsing="false" onAction="#handleShowCredits" styleClass="sidebar-button"
                text="💰   Gestion des Trajets" />
        <Button fx:id="btnCommunaute" alignment="BASELINE_LEFT" maxWidth="Infinity"
                mnemonicParsing="false" onAction="#handleShowCommunaute" styleClass="sidebar-button"
                text="💬   Gestion Communauté" />
        <Button fx:id="btnCashback" alignment="BASELINE_LEFT" maxWidth="Infinity"
                mnemonicParsing="false" onAction="#handleShowCashback" styleClass="sidebar-button"
                text="🎁   Gestion des Promotions" />


        <Region VBox.vgrow="ALWAYS" />

        <VBox spacing="5.0">
            <VBox.margin>
                <Insets bottom="20.0" />
            </VBox.margin>
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-padding: 0 0 0 20;" text="SYSTÈME" />
            <Button fx:id="btnParametres" alignment="BASELINE_LEFT" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleShowSettings" styleClass="sidebar-button"
                    text="⚙️   Paramètres" />
            <Button fx:id="btnDeconnexion" alignment="BASELINE_LEFT" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-button"
                    text="🚪   Déconnexion" />
        </VBox>
    </VBox>

    <!-- MAIN CONTENT AREA -->
    <StackPane fx:id="mainContentStack" AnchorPane.bottomAnchor="0.0"
               AnchorPane.leftAnchor="260.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <!-- VIEW UTILISATEURS -->
        <ScrollPane fitToWidth="true" styleClass="main-scroll-pane">
            <VBox spacing="20.0" styleClass="content-area">

                <!-- HEADER avec badge de notification -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <VBox>
                        <Label styleClass="header-label" text="Gestion des Utilisateurs" />
                        <Label styleClass="header-subtitle" text="Aperçu et gestion des comptes utilisateurs" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />

                    <!-- Admin Profile avec badge de notification -->
                    <HBox alignment="CENTER" spacing="10.0" styleClass="profile-chip">
                        <Circle fill="#e2e8f0" radius="16.0" stroke="WHITE" strokeType="INSIDE" />
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155; -fx-font-size: 13px;" text="Admin" />

                        <!-- 🔔 BADGE NOTIFICATION 1 - Profil admin (AVEC CLASSES CSS) -->
                        <StackPane>
                            <Button fx:id="btnNotifications" onAction="#handleViewNotifications"
                                    styleClass="notification-button"
                                    text="🔔" />
                            <Label fx:id="notificationBadge"
                                   styleClass="notification-badge"
                                   text="0" visible="false" managed="false"
                                   StackPane.alignment="TOP_RIGHT" />
                        </StackPane>
                    </HBox>
                </HBox>

                <!-- STATS ROW -->
                <HBox spacing="15.0">
                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-users" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 24px;" text="👥" />
                        <VBox>
                            <Label styleClass="stat-title" text="Total Utilisateurs" />
                            <Label fx:id="totalUsersLabel" styleClass="stat-value" text="0" />
                        </VBox>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-admins" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 24px;" text="👑" />
                        <VBox>
                            <Label styleClass="stat-title" text="Administrateurs" />
                            <Label fx:id="adminCountLabel" styleClass="stat-value" text="0" />
                        </VBox>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-users-standard" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 24px;" text="👤" />
                        <VBox>
                            <Label styleClass="stat-title" text="Utilisateurs" />
                            <Label fx:id="userCountLabel" styleClass="stat-value" text="0" />
                        </VBox>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-banned" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 24px;" text="🚫" />
                        <VBox>
                            <Label styleClass="stat-title" text="Suspendus" />
                            <Label fx:id="bannedCountLabel" styleClass="stat-value" text="0" />
                        </VBox>
                    </HBox>
                </HBox>

                <!-- SEARCH & FILTERS -->
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="search-box" HBox.hgrow="ALWAYS">
                        <padding>
                            <Insets bottom="8.0" left="15.0" right="15.0" top="8.0" />
                        </padding>
                        <Label text="🔍" textFill="#94a3b8" />
                        <TextField fx:id="searchField" promptText="Rechercher un utilisateur..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                    </HBox>

                    <ComboBox fx:id="filterRoleCombo" promptText="Filtrer par rôle" styleClass="filter-combo" prefWidth="150.0" />
                    <ComboBox fx:id="filterStatusCombo" promptText="Filtrer par statut" styleClass="filter-combo" prefWidth="150.0" />
                    <Button fx:id="btnResetFilters" onAction="#resetFilters" styleClass="secondary-button" text="✖ Réinitialiser" />
                </HBox>

                <!-- TABLEAU UTILISATEURS -->
                <VBox spacing="15.0" styleClass="card" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="card-title" text="📋 Liste des utilisateurs" />
                        <Region HBox.hgrow="ALWAYS" />
                        <!-- Boutons d'action avec badge de notification -->
                        <HBox spacing="8.0">
                            <Button onAction="#handleExportPDF" styleClass="secondary-button" text="📄 PDF" />
                            <Button onAction="#handleViewLogs" styleClass="secondary-button" text="📋 Logs" />

                            <!-- 🔔 BADGE NOTIFICATION 2 - Bouton Notifications avec badge (AVEC CLASSES CSS) -->
                            <StackPane>
                                <Button onAction="#handleViewNotifications" styleClass="secondary-button" text="🔔 Notifications" />
                                <Label fx:id="notificationBadgeTable"
                                       styleClass="notification-badge-table"
                                       text="0" visible="false" managed="false"
                                       StackPane.alignment="TOP_RIGHT" />
                            </StackPane>

                            <Button onAction="#handleAddPoints" styleClass="secondary-button" text="🏆 Points" />
                        </HBox>
                    </HBox>

                    <TableView fx:id="usersTable" prefHeight="350.0" VBox.vgrow="ALWAYS" onMouseClicked="#handleRowSelection">
                        <columns>
                            <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                            <TableColumn fx:id="colAvatar" prefWidth="60" text="" />
                            <TableColumn fx:id="colNomComplet" prefWidth="150" text="Nom &amp; Prénom" />
                            <TableColumn fx:id="colEmail" prefWidth="180" text="Email" />
                            <TableColumn fx:id="colTelephone" prefWidth="100" text="Téléphone" />
                            <TableColumn fx:id="colDateNaiss" prefWidth="100" text="Date naiss." />
                            <TableColumn fx:id="colRole" prefWidth="80" text="Rôle" />
                            <TableColumn fx:id="colStatus" prefWidth="90" text="Statut" />
                            <TableColumn fx:id="colActions" prefWidth="200" text="Actions" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <!-- FORMULAIRE ET PHOTO CÔTE À CÔTE -->
                <HBox spacing="25.0" VBox.vgrow="ALWAYS">

                    <!-- FORMULAIRE UTILISATEUR (gauche) -->
                    <VBox minWidth="320.0" prefWidth="350.0" spacing="15.0" styleClass="card">
                        <Label styleClass="card-title" text="📝 Informations utilisateur" />

                        <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                            <TextField fx:id="txtId" visible="false" managed="false" />

                            <GridPane hgap="10.0" vgap="10.0">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50" />
                                    <ColumnConstraints percentWidth="50" />
                                </columnConstraints>

                                <!-- Prénom -->
                                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label styleClass="form-label" text="👤 Prénom *" />
                                    <TextField fx:id="txtPrenom" promptText="Ahmed" styleClass="text-field" />
                                </VBox>

                                <!-- Nom -->
                                <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label styleClass="form-label" text="👤 Nom *" />
                                    <TextField fx:id="txtNom" promptText="Ben Ali" styleClass="text-field" />
                                </VBox>

                                <!-- Label erreur Prénom -->
                                <Label fx:id="errorPrenom" styleClass="error-label" text="" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                                <!-- Label erreur Nom -->
                                <Label fx:id="errorNom" styleClass="error-label" text="" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <!-- Date naissance -->
                                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                                    <Label styleClass="form-label" text="📅 Date de naissance" />
                                    <DatePicker fx:id="dpDateNaiss" promptText="JJ/MM/AAAA" styleClass="date-picker" />
                                </VBox>

                                <!-- Label erreur Date -->
                                <Label fx:id="errorDate" styleClass="error-label" text="" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2" />

                                <!-- Email -->
                                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2">
                                    <Label styleClass="form-label" text="📧 Email *" />
                                    <TextField fx:id="txtEmail" promptText="exemple@re7la.tn" styleClass="text-field" />
                                </VBox>

                                <!-- Label erreur Email -->
                                <Label fx:id="errorEmail" styleClass="error-label" text="" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2" />

                                <!-- Téléphone -->
                                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="6" GridPane.columnSpan="2">
                                    <Label styleClass="form-label" text="📞 Téléphone" />
                                    <TextField fx:id="txtTelephone" promptText="+216 99 999 999" styleClass="text-field" />
                                </VBox>

                                <!-- Label erreur Téléphone -->
                                <Label fx:id="errorTelephone" styleClass="error-label" text="" GridPane.columnIndex="0" GridPane.rowIndex="7" GridPane.columnSpan="2" />

                                <!-- Mot de passe -->
                                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="8" GridPane.columnSpan="2">
                                    <Label styleClass="form-label" text="🔒 Mot de passe" />
                                    <PasswordField fx:id="txtPassword" promptText="••••••••" styleClass="text-field" />
                                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10px;" text="Laissez vide pour conserver l'actuel" />
                                </VBox>

                                <!-- Label erreur Mot de passe -->
                                <Label fx:id="errorPassword" styleClass="error-label" text="" GridPane.columnIndex="0" GridPane.rowIndex="9" GridPane.columnSpan="2" />

                                <!-- Rôle -->
                                <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="10">
                                    <Label styleClass="form-label" text="👑 Rôle *" />
                                    <ComboBox fx:id="comboRole" promptText="Sélectionner un rôle" styleClass="combo-box" prefWidth="150.0" />
                                </VBox>

                                <!-- Statut -->
                                <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="10">
                                    <Label styleClass="form-label" text="⚡ Statut *" />
                                    <ComboBox fx:id="comboStatus" promptText="Sélectionner un statut" styleClass="combo-box" prefWidth="150.0" />
                                </VBox>

                                <!-- Label erreur Rôle -->
                                <Label fx:id="errorRole" styleClass="error-label" text="" GridPane.columnIndex="0" GridPane.rowIndex="11" />

                                <!-- Label erreur Statut -->
                                <Label fx:id="errorStatus" styleClass="error-label" text="" GridPane.columnIndex="1" GridPane.rowIndex="11" />
                            </GridPane>
                        </VBox>

                        <!-- BUTTONS -->
                        <VBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                            <HBox spacing="10.0">
                                <Button fx:id="btnAjouter" maxWidth="Infinity" mnemonicParsing="false"
                                        onAction="#ajouterUtilisateur" prefHeight="40.0" styleClass="action-button"
                                        text="➕   Ajouter" HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnModifier" maxWidth="Infinity" mnemonicParsing="false"
                                        onAction="#modifierUtilisateur" prefHeight="40.0" styleClass="edit-button"
                                        text="✏️   Modifier" HBox.hgrow="ALWAYS" disable="true" />
                            </HBox>
                            <HBox spacing="10.0">
                                <Button fx:id="btnSupprimer" maxWidth="Infinity" mnemonicParsing="false"
                                        onAction="#supprimerUtilisateur" prefHeight="40.0" styleClass="delete-button"
                                        text="🗑️   Supprimer" HBox.hgrow="ALWAYS" disable="true" />
                                <Button fx:id="btnAnnuler" maxWidth="Infinity" mnemonicParsing="false"
                                        onAction="#handleCancel" prefHeight="40.0" styleClass="cancel-button"
                                        text="✖   Annuler" HBox.hgrow="ALWAYS" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- COLONNE DE DROITE - IMAGE PREVIEW -->
                    <VBox spacing="15.0" prefWidth="220.0" styleClass="card-image">
                        <Label styleClass="card-title" text="📸 Photo de profil" />

                        <VBox fx:id="imagePreviewBox" alignment="CENTER" spacing="15.0"
                              styleClass="image-preview-box-large" visible="true" managed="true">

                            <StackPane>
                                <Circle radius="75.0" styleClass="preview-circle-large" />
                                <Circle radius="70.0" styleClass="preview-circle-inner" />
                                <ImageView fx:id="previewImageView" fitHeight="130.0" fitWidth="130.0"
                                           preserveRatio="true" styleClass="preview-image-large" />
                            </StackPane>

                            <Label fx:id="imageFileNameLabel" styleClass="image-filename" text="Aucune image" />

                            <TextField fx:id="txtImage" promptText="URL de l'image" styleClass="text-field" visible="false" managed="false" />

                            <Button fx:id="btnParcourirImage" onAction="#handleBrowseImage" styleClass="browse-button-large"
                                    text="📁 Choisir une image" prefWidth="200.0" />

                            <!-- Label erreur Image -->
                            <Label fx:id="errorImage" styleClass="error-label" text="" />

                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11px; -fx-text-alignment: center;"
                                   text="Cliquez pour sélectionner une image depuis votre PC" wrapText="true" />
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </StackPane>
</AnchorPane>