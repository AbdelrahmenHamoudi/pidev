<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.Controllers.promotion.frontoffice.ModifierReservationDialogController"
      spacing="20"
      style="-fx-background-color: white; -fx-padding: 25;">

    <!-- TITRE -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Text text="✏️" style="-fx-font-size: 28px;"/>
        <VBox>
            <Text text="Modifier la Réservation"
                  style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>
            <Text fx:id="txtNomPromo" text="Été 2025"
                  style="-fx-font-size: 14px; -fx-fill: #64748B;"/>
        </VBox>
    </HBox>

    <Separator/>

    <!-- INFOS PROMOTION -->
    <VBox spacing="10" style="-fx-background-color: #F9FAFB; -fx-padding: 15; -fx-background-radius: 10;">
        <Text text="📋 Détails de la promotion"
              style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>

        <HBox spacing="20">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Text text="Période valable" style="-fx-font-size: 12px; -fx-fill: #64748B;"/>
                <Text fx:id="txtPeriodePromo" text="01/06/2025 - 31/08/2025"
                      style="-fx-font-size: 13px; -fx-fill: #2C3E50; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Text text="Réduction" style="-fx-font-size: 12px; -fx-fill: #64748B;"/>
                <Text fx:id="txtReduction" text="-20%"
                      style="-fx-font-size: 13px; -fx-fill: #F39C12; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Text text="Prix par jour" style="-fx-font-size: 12px; -fx-fill: #64748B;"/>
                <Text fx:id="txtPrixParJour" text=""
                      style="-fx-font-size: 13px; -fx-fill: #2C3E50; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- NOUVELLE PÉRIODE -->
    <VBox spacing="12">
        <Text text="📅 Nouvelle période de réservation"
              style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>

        <GridPane hgap="15" vgap="10">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <VBox spacing="5" GridPane.columnIndex="0">
                <Text text="Date début *" style="-fx-font-size: 12px; -fx-fill: #64748B;"/>
                <DatePicker fx:id="dateDebutPicker" prefWidth="200" styleClass="text-field"/>
            </VBox>

            <VBox spacing="5" GridPane.columnIndex="1">
                <Text text="Date fin *" style="-fx-font-size: 12px; -fx-fill: #64748B;"/>
                <DatePicker fx:id="dateFinPicker" prefWidth="200" styleClass="text-field"/>
            </VBox>
        </GridPane>
    </VBox>

    <!-- NOUVEAU CALCUL -->
    <VBox spacing="10" style="-fx-background-color: #FFF9F0; -fx-padding: 15; -fx-background-radius: 10;">
        <Text text="💰 Nouveau calcul"
              style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>

        <GridPane hgap="15" vgap="8">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <VBox spacing="3" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Text text="Nombre de jours" style="-fx-font-size: 12px; -fx-fill: #64748B;"/>
                <Text fx:id="txtNbJours" text="0 jour(s)"
                      style="-fx-font-size: 14px; -fx-fill: #2C3E50; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="3" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Text text="Prix original" style="-fx-font-size: 12px; -fx-fill: #64748B;"/>
                <Text fx:id="txtPrixOriginal" text="0.00 TND"
                      style="-fx-font-size: 13px; -fx-fill: #2C3E50;"/>
            </VBox>

            <VBox spacing="3" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Text text="Réduction appliquée" style="-fx-font-size: 12px; -fx-fill: #64748B;"/>
                <Text fx:id="txtReductionMontant" text="-0.00 TND"
                      style="-fx-font-size: 13px; -fx-fill: #E67E22;"/>
            </VBox>
        </GridPane>

        <Separator/>

        <HBox spacing="10" alignment="CENTER">
            <Text text="Nouveau montant total :"
                  style="-fx-font-size: 16px; -fx-fill: #2C3E50; -fx-font-weight: bold;"/>
            <Text fx:id="txtPrixFinal" text="0.00 TND"
                  style="-fx-font-size: 22px; -fx-fill: #1ABC9C; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>

    <!-- BOUTONS -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <padding>
            <Insets top="10"/>
        </padding>

        <Button text="Annuler" onAction="#handleCancel"
                style="-fx-background-color: #E2E8F0; -fx-text-fill: #2C3E50;
                       -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 8;
                       -fx-cursor: hand;" prefWidth="120"/>

        <Button fx:id="btnConfirmer" text="✅ Enregistrer" onAction="#handleConfirmer"
                style="-fx-background-color: #3498DB; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 8;
                       -fx-cursor: hand;" prefWidth="140"/>
    </HBox>

</VBox>