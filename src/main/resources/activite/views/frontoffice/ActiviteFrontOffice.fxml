<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controllers.activite.ActiviteFrontOfficeController"
            styleClass="front-container"
            stylesheets="/activite/css/re7la-styles.css">

    <!-- ================= HEADER ================= -->
    <top>
        <VBox styleClass="front-header" spacing="15">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <ImageView fitWidth="90" preserveRatio="true">
                    <image>
                        <Image url="@/activite/images/logo.png"/>
                    </image>
                </ImageView>

                <VBox spacing="5">
                    <Text text="RE7LA" styleClass="front-title"/>
                    <Text text="Découvrez des expériences inoubliables" styleClass="front-subtitle"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- ✅ NOUVEAU: Bouton Accueil -->
                <Button text="🏠 Accueil"
                        onAction="#goToAccueil"
                        style="-fx-background-color: #3B82F6; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 15;
                               -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.3), 8, 0, 0, 2);"/>

                <!-- ✅ NOUVEAU: Bouton Profil -->
                <Button text="👤 Mon Profil"
                        onAction="#goToProfil"
                        style="-fx-background-color: #10B981; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 15;
                               -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.3), 8, 0, 0, 2);"/>

                <!-- ✅ Informations utilisateur (sera rempli par le contrôleur) -->
                <HBox fx:id="userHeader" spacing="10" alignment="CENTER"
                      style="-fx-background-color: #F9FAFB; -fx-padding: 8 15; -fx-background-radius: 20;">
                    <Text text="👤" style="-fx-font-size: 16px;"/>
                    <Label fx:id="userNameLabel"
                           style="-fx-font-size: 13px; -fx-text-fill: #2C3E50; -fx-font-weight: bold;"
                           text="Chargement..."/>
                </HBox>
            </HBox>

            <HBox spacing="15" alignment="CENTER">
                <TextField fx:id="searchField"
                           promptText="🔍 Rechercher une activité, un lieu..."
                           styleClass="search-box"
                           HBox.hgrow="ALWAYS"/>
                <Button text="Rechercher" styleClass="btn-primary"/>
            </HBox>
        </VBox>
    </top>

    <!-- ================= CENTER ================= -->
    <center>
        <ScrollPane fitToWidth="true"
                    pannable="true"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">

            <HBox spacing="25">
                <padding>
                    <Insets top="25" right="25" bottom="25" left="25"/>
                </padding>

                <!-- ================= SIDEBAR ================= -->
                <VBox styleClass="filter-box" spacing="20" prefWidth="280" maxWidth="280">
                    <Text text="🔎 Filtres" styleClass="filter-title"/>
                    <Separator/>

                    <VBox spacing="10">
                        <Label text="Type d'activité" styleClass="filter-label"/>
                        <VBox fx:id="typeFiltersBox" spacing="8"/>
                    </VBox>

                    <Separator/>

                    <VBox spacing="10">
                        <Label text="Prix maximum (DT)" styleClass="filter-label"/>
                        <Slider fx:id="prixSlider" min="0" max="200" value="200"
                                majorTickUnit="50" blockIncrement="10"
                                showTickLabels="true" showTickMarks="true"/>
                        <Text fx:id="prixText" text="0 - 200 DT"/>
                    </VBox>

                    <Separator/>

                    <VBox spacing="10">
                        <Label text="Lieu" styleClass="filter-label"/>
                        <ComboBox fx:id="lieuCombo" promptText="Tous les lieux" prefWidth="250"/>
                    </VBox>

                    <Separator/>

                    <CheckBox fx:id="disponibleCheckbox"
                              text="Uniquement disponibles"
                              selected="true"/>

                    <Region VBox.vgrow="ALWAYS"/>

                    <Button text="🔄 Réinitialiser les filtres"
                            styleClass="btn-secondary"
                            maxWidth="Infinity"
                            onAction="#resetFilters"/>
                </VBox>

                <!-- ================= ACTIVITIES AREA ================= -->
                <VBox spacing="20" HBox.hgrow="ALWAYS">

                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Text fx:id="resultsCountText"
                              text="0 activités trouvées"
                              style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label text="Trier par:" style="-fx-text-fill: #7F8C8D;"/>

                        <ComboBox fx:id="sortCombo" value="Popularité" prefWidth="150">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Popularité"/>
                                    <String fx:value="Prix croissant"/>
                                    <String fx:value="Prix décroissant"/>
                                    <String fx:value="Nom A-Z"/>
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </HBox>

                    <ScrollPane fitToWidth="true"
                                VBox.vgrow="ALWAYS"
                                style="-fx-background-color: transparent; -fx-border-color: transparent;">

                        <!-- 4 cards × 210px + 3 gaps × 15px = 885px -->
                        <FlowPane fx:id="activitiesFlowPane"
                                  VBox.vgrow="ALWAYS"
                                  alignment="TOP_LEFT">
                            <padding>
                                <Insets top="5" right="5" bottom="10" left="5"/>
                            </padding>
                        </FlowPane>

                    </ScrollPane>

                </VBox>
            </HBox>
        </ScrollPane>
    </center>

</BorderPane>