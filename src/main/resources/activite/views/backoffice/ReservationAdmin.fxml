<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controllers.activite.ReservationsAdminController"
            prefWidth="1100" prefHeight="750"
            style="-fx-background-color:#F7F4EF;">

    <top>
        <VBox style="-fx-background-color:linear-gradient(to right,#1A1A2E,#0F3460);-fx-padding:20 28;">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <Label text="🛡️" style="-fx-font-size:26px;"/>
                <VBox>
                    <Label text="Gestion des Réservations"
                           style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                    <Label text="Toutes les réservations de tous les utilisateurs"
                           style="-fx-font-size:12px;-fx-text-fill:#94A3B8;"/>
                </VBox>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="🔄 Actualiser" onAction="#refresh"
                        style="-fx-background-color:rgba(255,255,255,0.15);-fx-text-fill:white;
                               -fx-padding:8 18;-fx-background-radius:8;-fx-cursor:hand;"/>
            </HBox>

            <!-- Stats -->
            <HBox spacing="16" style="-fx-padding:14 0 0 0;">
                <VBox alignment="CENTER" spacing="2"
                      style="-fx-background-color:rgba(255,255,255,0.1);-fx-padding:10 22;
                             -fx-background-radius:10;-fx-border-color:rgba(255,255,255,0.2);-fx-border-radius:10;">
                    <Label fx:id="lblTotal" text="0"
                           style="-fx-font-size:26px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                    <Label text="Total" style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="2"
                      style="-fx-background-color:rgba(52,211,153,0.15);-fx-padding:10 22;
                             -fx-background-radius:10;-fx-border-color:rgba(52,211,153,0.4);-fx-border-radius:10;">
                    <Label fx:id="lblConfirmees" text="0"
                           style="-fx-font-size:26px;-fx-font-weight:bold;-fx-text-fill:#34D399;"/>
                    <Label text="Confirmées" style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="2"
                      style="-fx-background-color:rgba(248,113,113,0.15);-fx-padding:10 22;
                             -fx-background-radius:10;-fx-border-color:rgba(248,113,113,0.4);-fx-border-radius:10;">
                    <Label fx:id="lblAnnulees" text="0"
                           style="-fx-font-size:26px;-fx-font-weight:bold;-fx-text-fill:#F87171;"/>
                    <Label text="Annulées" style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox>
            <!-- Barre filtres -->
            <HBox alignment="CENTER_LEFT" spacing="14"
                  style="-fx-background-color:white;-fx-padding:12 20;
                         -fx-border-color:#E2E8F0;-fx-border-width:0 0 1 0;">
                <TextField fx:id="searchField" promptText="🔍  Rechercher (user, activité, lieu)..."
                           prefWidth="300"
                           style="-fx-background-radius:8;-fx-border-color:#CBD5E1;-fx-border-radius:8;-fx-padding:8;"/>
                <Label text="Statut :" style="-fx-font-weight:bold;-fx-text-fill:#475569;"/>
                <ComboBox fx:id="filtreStatut" prefWidth="140"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblPagination" text="0 réservation(s)"
                       style="-fx-text-fill:#64748B;-fx-font-size:12px;"/>
            </HBox>

            <!-- Tableau -->
            <TableView fx:id="table" VBox.vgrow="ALWAYS"
                       style="-fx-background-color:white;">
                <columns>
                    <TableColumn fx:id="colId"       text="ID"        prefWidth="55"/>
                    <TableColumn fx:id="colUser"     text="Utilisateur" prefWidth="160"/>
                    <TableColumn fx:id="colActivite" text="Activité"  prefWidth="180"/>
                    <TableColumn fx:id="colLieu"     text="Lieu"      prefWidth="130"/>
                    <TableColumn fx:id="colDate"     text="Date"      prefWidth="100"/>
                    <TableColumn fx:id="colHoraire"  text="Horaire"   prefWidth="110"/>
                    <TableColumn fx:id="colStatut"   text="Statut"    prefWidth="110"/>
                    <TableColumn fx:id="colActions"  text="Actions"   prefWidth="160"/>
                </columns>
                <placeholder>
                    <Label text="Aucune réservation trouvée."
                           style="-fx-text-fill:#94A3B8;-fx-font-style:italic;"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>
</BorderPane>
