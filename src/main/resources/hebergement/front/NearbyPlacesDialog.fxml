<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.Controllers.hebergement.front.NearbyPlacesController"
      styleClass="nearby-root"
      stylesheets="@StyleNearby.css"
      spacing="0"
      prefWidth="680"
      prefHeight="660">

    <!-- ══════════════════════════════════════════════ -->
    <!-- HEADER                                         -->
    <!-- ══════════════════════════════════════════════ -->
    <VBox styleClass="header-panel" spacing="0">

        <!-- Top bar : titre + close -->
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="header-top">
            <StackPane styleClass="header-icon-wrap">
                <Label text="🗺" styleClass="header-map-icon"/>
            </StackPane>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label fx:id="cityTitleLabel"    text="Lieux à proximité" styleClass="header-title"/>
                <Label fx:id="citySubtitleLabel" text="Chargement en cours…"  styleClass="header-subtitle"/>
            </VBox>
            <Button text="✕" styleClass="btn-close" onAction="#closeDialog"/>
        </HBox>

        <!-- Séparateur décoratif -->
        <Region styleClass="header-divider"/>

        <!-- Barre de filtres -->
        <ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                    styleClass="filter-scroll" prefHeight="54">
            <HBox fx:id="categoryBar" styleClass="filter-bar" spacing="6" alignment="CENTER_LEFT">
                <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
                <Button text="Tous"          styleClass="chip-active"  onAction="#filterAll"/>
                <Button text="Restaurants"   styleClass="chip"         onAction="#filterRestaurants"/>
                <Button text="Cafés"         styleClass="chip"         onAction="#filterCafes"/>
                <Button text="Plages"        styleClass="chip"         onAction="#filterBeaches"/>
                <Button text="Attractions"   styleClass="chip"         onAction="#filterAttractions"/>
                <Button text="Hôpitaux"      styleClass="chip"         onAction="#filterHospitals"/>
                <Button text="Supermarchés"  styleClass="chip"         onAction="#filterSupermarkets"/>
            </HBox>
        </ScrollPane>
    </VBox>

    <!-- ══════════════════════════════════════════════ -->
    <!-- LOADING BAR                                    -->
    <!-- ══════════════════════════════════════════════ -->
    <StackPane fx:id="loadingPane" styleClass="loading-strip" prefHeight="48">
        <HBox alignment="CENTER" spacing="14">
            <ProgressIndicator fx:id="loadingIndicator" prefWidth="18" prefHeight="18"
                               styleClass="loading-spinner"/>
            <Label fx:id="loadingLabel" text="Chargement…" styleClass="loading-text"/>
        </HBox>
    </StackPane>

    <!-- ══════════════════════════════════════════════ -->
    <!-- LISTE DES LIEUX                                -->
    <!-- ══════════════════════════════════════════════ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="list-scroll">
        <VBox fx:id="placesList" styleClass="places-container" spacing="8">
            <padding><Insets top="16" right="18" bottom="16" left="18"/></padding>
        </VBox>
    </ScrollPane>

    <!-- ══════════════════════════════════════════════ -->
    <!-- FOOTER                                         -->
    <!-- ══════════════════════════════════════════════ -->
    <VBox styleClass="footer-panel" spacing="12">
        <!-- Stats row -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="statsLabel" text="—" styleClass="stats-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="6" alignment="CENTER" styleClass="badge-powered">
                <Label text="●" styleClass="badge-dot"/>
                <Label text="Geoapify" styleClass="badge-text"/>
            </HBox>
            <Label text="Rayon 3 km" styleClass="radius-label"/>
        </HBox>
        <!-- Map button -->
        <Button text="Ouvrir dans OpenStreetMap  →"
                onAction="#openMapInBrowser"
                maxWidth="Infinity"
                styleClass="btn-map"/>
    </VBox>

</VBox>