<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controllers.Trajet.AssistantVocalController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #F8FAFC;">

    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
          spacing="0">

        <!-- ═══════════════ HEADER ═══════════════ -->
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: linear-gradient(to right, #4F46E5, #7C3AED);
                     -fx-padding: 16 24;">

            <Label text="🤖" style="-fx-font-size: 28px;"/>

            <VBox spacing="2">
                <Label text="Assistant Vocal RE7LA"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label fx:id="lblStatut" text="✅ Prêt"
                       style="-fx-text-fill: #C7D2FE; -fx-font-size: 12px;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER" spacing="3">
                <Label text="Langue" style="-fx-text-fill: #C7D2FE; -fx-font-size: 10px;"/>
                <ComboBox fx:id="langueCombo"
                          prefWidth="130"
                          style="-fx-background-radius: 20; -fx-font-size: 12px;"/>
            </VBox>

            <Label fx:id="lblLangue" text="FR Français"
                   style="-fx-text-fill: white; -fx-font-size: 12px; -fx-opacity: 0.7;"/>

            <Button text="Effacer"
                    onAction="#effacerConversation"
                    style="-fx-background-color: rgba(255,255,255,0.15);
                           -fx-text-fill: white;
                           -fx-background-radius: 20;
                           -fx-padding: 6 14;
                           -fx-cursor: hand;
                           -fx-font-size: 12px;"/>
        </HBox>

        <!-- ═══════════════ CORPS ═══════════════ -->
        <HBox spacing="0" VBox.vgrow="ALWAYS">

            <!-- ─── SIDEBAR GAUCHE ─── -->
            <VBox spacing="0" prefWidth="260"
                  style="-fx-background-color: #FFFFFF;
                         -fx-border-color: #E5E7EB;
                         -fx-border-width: 0 1 0 0;">

                <VBox fx:id="rapportPanel" spacing="10"
                      style="-fx-padding: 16; -fx-background-color: #EFF6FF;
                             -fx-border-color: #BFDBFE; -fx-border-width: 0 0 1 0;">

                    <Label text="Trajet en cours"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #1E40AF;"/>

                    <Label fx:id="lblRapportInfo"
                           text="Aucun trajet actif"
                           style="-fx-font-size: 11px; -fx-text-fill: #374151; -fx-wrap-text: true;"
                           wrapText="true"/>

                    <Button text="Generer Rapport"
                            onAction="#genererRapport"
                            maxWidth="Infinity"
                            style="-fx-background-color: #1D4ED8;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-cursor: hand;
                                   -fx-padding: 7 12;
                                   -fx-font-size: 12px;"/>
                </VBox>

                <VBox spacing="10"
                      style="-fx-padding: 16; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;">

                    <Label text="Signalement rapide"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #92400E;"/>

                    <Label fx:id="lblProblemeStatus"
                           text="Aucun probleme signale"
                           style="-fx-font-size: 11px; -fx-text-fill: #6B7280;"/>

                    <FlowPane fx:id="problemesRapides" hgap="6" vgap="6"/>
                </VBox>

                <VBox spacing="8" style="-fx-padding: 16;" VBox.vgrow="ALWAYS">
                    <Label text="Commandes rapides"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #374151;"/>

                    <VBox spacing="5">
                        <Label text="FR Francais"
                               style="-fx-text-fill: #6B7280; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <Label text="Quel est mon itineraire ?"
                               style="-fx-font-size: 11px; -fx-text-fill: #4B5563;" wrapText="true"/>
                        <Label text="Signaler une panne"
                               style="-fx-font-size: 11px; -fx-text-fill: #4B5563;"/>
                        <Label text="Generer mon rapport"
                               style="-fx-font-size: 11px; -fx-text-fill: #4B5563;"/>

                        <Label text="SA Arabe"
                               style="-fx-text-fill: #6B7280; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <Label text="ما هو مساري"
                               style="-fx-font-size: 11px; -fx-text-fill: #4B5563;"/>
                        <Label text="الإبلاغ عن عطل"
                               style="-fx-font-size: 11px; -fx-text-fill: #4B5563;"/>

                        <Label text="GB English"
                               style="-fx-text-fill: #6B7280; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <Label text="What's my route?"
                               style="-fx-font-size: 11px; -fx-text-fill: #4B5563;"/>
                        <Label text="Report a breakdown"
                               style="-fx-font-size: 11px; -fx-text-fill: #4B5563;"/>
                    </VBox>
                </VBox>
            </VBox>

            <!-- ─── ZONE CHAT ─── -->
            <VBox spacing="0" HBox.hgrow="ALWAYS">

                <ScrollPane fx:id="chatScroll"
                            fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC; -fx-border-width: 0;">

                    <VBox fx:id="chatContainer" spacing="12"
                          style="-fx-padding: 20; -fx-background-color: #F8FAFC;">
                    </VBox>
                </ScrollPane>

                <!-- ─── BARRE SAISIE ─── -->
                <VBox spacing="0"
                      style="-fx-background-color: white;
                             -fx-border-color: #E5E7EB;
                             -fx-border-width: 1 0 0 0;
                             -fx-padding: 12 16;">

                    <!-- FIX : visible="false" par défaut, géré par le controller -->
                    <HBox fx:id="enregistrementIndicateur"
                          alignment="CENTER"
                          visible="false"
                          managed="false"
                          style="-fx-padding: 0 0 8 0;">
                        <StackPane>
                            <Circle fx:id="circleAnimation"
                                    radius="22"
                                    fill="#EEF2FF"
                                    stroke="#A5B4FC"
                                    strokeWidth="2"/>
                        </StackPane>
                        <Label fx:id="lblEnregistrement"
                               text=" Enregistrement en cours..."
                               style="-fx-text-fill: #EF4444; -fx-font-size: 11px;"/>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER">

                        <Button fx:id="btnMicro"
                                text="Parler"
                                onAction="#toggleMicro"
                                style="-fx-background-color: #6366F1;
                                       -fx-text-fill: white;
                                       -fx-background-radius: 50;
                                       -fx-min-width: 60;
                                       -fx-min-height: 60;
                                       -fx-font-size: 14px;
                                       -fx-cursor: hand;"/>

                        <TextField fx:id="txtMessage"
                                   promptText="Tapez votre message ou utilisez le micro..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-radius: 25;
                                          -fx-border-radius: 25;
                                          -fx-border-color: #D1D5DB;
                                          -fx-border-width: 1;
                                          -fx-padding: 12 16;
                                          -fx-font-size: 13px;"
                                   onAction="#envoyerMessage"/>

                        <Button fx:id="btnEnvoyer"
                                text="&gt;"
                                onAction="#envoyerMessage"
                                style="-fx-background-color: #6366F1;
                                       -fx-text-fill: white;
                                       -fx-background-radius: 50;
                                       -fx-min-width: 48;
                                       -fx-min-height: 48;
                                       -fx-font-size: 18px;
                                       -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</AnchorPane>
