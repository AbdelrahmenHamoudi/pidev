<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Circle?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controllers.communaute.CommunauteController"
            styleClass="front-container"
            stylesheets="@/communaute/Communaute.css">

    <!-- ================= HEADER ================= -->
    <top>
        <VBox styleClass="front-header" spacing="15">
            <HBox alignment="CENTER_LEFT" spacing="20">

                <!-- ── Circular Logo ── -->
                <StackPane alignment="CENTER">
                    <Circle radius="48" fill="#F39C12"
                            style="-fx-effect: dropshadow(gaussian, rgba(243,156,18,0.75), 22, 0.5, 0, 0);"/>
                    <Circle radius="44" fill="white"/>
                    <ImageView fx:id="logoImageView" fitWidth="82" fitHeight="82"
                               preserveRatio="false" smooth="true"/>
                </StackPane>

                <HBox alignment="CENTER_LEFT" spacing="20" HBox.hgrow="ALWAYS">
                    <VBox spacing="5">
                        <Text text="RE7LA" styleClass="front-title"/>
                        <Text text="Profitez de nos meilleures promotions" styleClass="front-subtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- ✅ NOUVEAU: Bouton Accueil -->
                    <Button text="🏠 Accueil"
                            onAction="#goToAccueil"
                            style="-fx-background-color: #3B82F6; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 15;
                                   -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.3), 8, 0, 0, 2);"/>

                    <!-- ✅ NOUVEAU: Bouton Profil -->
                    <Button text="👤 Mon Profil"
                            onAction="#goToProfil"
                            style="-fx-background-color: #10B981; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 15;
                                   -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.3), 8, 0, 0, 2);"/>

                    <!-- ✅ MODIFIÉ: Connected user info avec fx:id et styleClass -->
                    <HBox fx:id="userHeader" spacing="10" alignment="CENTER"
                          style="-fx-background-color: #F9FAFB; -fx-padding: 8 15; -fx-background-radius: 20;">
                        <Text text="👤" style="-fx-font-size: 16px;"/>
                        <Text styleClass="user-name" text="Chargement..."
                              style="-fx-font-size: 13px; -fx-fill: #2C3E50; -fx-font-weight: bold;"/>
                    </HBox>

                    <Button fx:id="btnMesReservations" text="📋 Mes Réservations"
                            onAction="#handleMesReservations"
                            style="-fx-background-color: #F39C12; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 15;
                                   -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(243,156,18,0.4), 8, 0, 0, 2);"/>
                </HBox>
            </HBox>

        </VBox>
    </top>

    <!-- ================= CENTER ================= -->
    <center>
        <StackPane fx:id="rootStackPane" pickOnBounds="false">
            <ScrollPane fitToWidth="true"
                        fitToHeight="true"
                        pannable="true"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">

                <HBox spacing="25">
                    <padding>
                        <Insets top="25" right="25" bottom="25" left="25"/>
                    </padding>

                    <!-- ================= SIDEBAR — Mini-jeux + Analytics ================= -->
                    <VBox spacing="16" prefWidth="260" maxWidth="260">

                        <!-- ── Mini-jeu launcher card ── -->
                        <VBox spacing="13"
                              style="-fx-background-color:white;
                                     -fx-background-radius:18;
                                     -fx-padding:20;
                                     -fx-effect:dropshadow(gaussian,rgba(44,62,80,0.09),12,0,0,4);
                                     -fx-border-color:#F39C12;
                                     -fx-border-radius:18;
                                     -fx-border-width:1.5;">

                            <!-- Header -->
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="🕹" style="-fx-font-size:26px;"/>
                                <VBox spacing="1">
                                    <Label text="Mini-jeux"
                                           style="-fx-font-size:16px;-fx-font-weight:800;-fx-text-fill:#2C3E50;"/>
                                    <Label text="Jouez entre publications !"
                                           style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                                </VBox>
                            </HBox>

                            <Separator/>

                            <!-- Brick Breaker -->
                            <Button text="🧱  Brick Breaker"
                                    maxWidth="Infinity"
                                    onAction="#openMiniGame"
                                    userData="https://s3t.itch.io/brick-break.html"
                                    style="-fx-background-color:linear-gradient(to right,#F39C12,#E67E22);
                                           -fx-text-fill:white;-fx-font-weight:800;-fx-font-size:13px;
                                           -fx-background-radius:14;-fx-padding:11 0;-fx-cursor:hand;
                                           -fx-effect:dropshadow(gaussian,rgba(243,156,18,0.45),8,0,0,3);"/>

                            <!-- 2048 -->
                            <Button text="🟦  2048"
                                    maxWidth="Infinity"
                                    onAction="#openMiniGame"
                                    userData="https://play2048.co/"
                                    style="-fx-background-color:linear-gradient(to right,#1ABC9C,#17A589);
                                           -fx-text-fill:white;-fx-font-weight:800;-fx-font-size:13px;
                                           -fx-background-radius:14;-fx-padding:11 0;-fx-cursor:hand;
                                           -fx-effect:dropshadow(gaussian,rgba(26,188,156,0.45),8,0,0,3);"/>

                            <!-- Tetris -->
                            <Button text="🟩  Tetris"
                                    maxWidth="Infinity"
                                    onAction="#openMiniGame"
                                    userData="https://tetr.io/"
                                    style="-fx-background-color:linear-gradient(to right,#6366F1,#8B5CF6);
                                           -fx-text-fill:white;-fx-font-weight:800;-fx-font-size:13px;
                                           -fx-background-radius:14;-fx-padding:11 0;-fx-cursor:hand;
                                           -fx-effect:dropshadow(gaussian,rgba(99,102,241,0.45),8,0,0,3);"/>

                            <!-- Snake -->
                            <Button text="🐍  Snake"
                                    maxWidth="Infinity"
                                    onAction="#openMiniGame"
                                    userData="https://www.google.com/fbx?fbx=snake_arcade"
                                    style="-fx-background-color:linear-gradient(to right,#2C3E50,#34495E);
                                           -fx-text-fill:white;-fx-font-weight:800;-fx-font-size:13px;
                                           -fx-background-radius:14;-fx-padding:11 0;-fx-cursor:hand;
                                           -fx-effect:dropshadow(gaussian,rgba(44,62,80,0.45),8,0,0,3);"/>

                            <!-- Sudoku -->
                            <Button text="🔢  Sudoku"
                                    maxWidth="Infinity"
                                    onAction="#openMiniGame"
                                    userData="https://sudoku.com/"
                                    style="-fx-background-color:linear-gradient(to right,#3B82F6,#2563EB);
                                           -fx-text-fill:white;-fx-font-weight:800;-fx-font-size:13px;
                                           -fx-background-radius:14;-fx-padding:11 0;-fx-cursor:hand;
                                           -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.45),8,0,0,3);"/>
                        </VBox>

                        <!-- ── Analytics / trending panel ── -->
                        <VBox fx:id="trendingPanel" spacing="10" visible="false" managed="false"
                              style="-fx-background-color:white;
                                     -fx-background-radius:16;
                                     -fx-padding:16;
                                     -fx-border-color:#FFB74D;
                                     -fx-border-radius:16;
                                     -fx-border-width:1.5;
                                     -fx-effect:dropshadow(gaussian,rgba(44,62,80,0.07),10,0,0,3);">

                            <Label fx:id="trendingTitle"
                                   text="🔥 Publication tendance"
                                   style="-fx-font-weight:800;-fx-font-size:13px;-fx-text-fill:#E65100;"/>
                            <Label fx:id="trendingDesc" text="" wrapText="true"
                                   style="-fx-font-size:12px;-fx-text-fill:#555;"/>
                            <Separator/>
                            <Label fx:id="mostReactedLabel"   text="⭐ Plus réagi: —"    wrapText="true" style="-fx-font-size:12px;-fx-text-fill:#333;"/>
                            <Label fx:id="mostCommentedLabel" text="💬 Plus commenté: —" wrapText="true" style="-fx-font-size:12px;-fx-text-fill:#333;"/>
                        </VBox>

                    </VBox>

                    <!-- ================= PUBLICATIONS AREA ================= -->
                    <VBox spacing="16" HBox.hgrow="ALWAYS">

                        <!-- ── Search + Sort + New pub toolbar ── -->
                        <VBox spacing="10"
                              style="-fx-background-color:white;-fx-background-radius:18;
                                     -fx-padding:16 18 14 18;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,3);
                                     -fx-border-color:#F39C12;-fx-border-radius:18;-fx-border-width:1.5;">

                            <!-- Row 1: count + new button -->
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label fx:id="resultsCountText"
                                       text="0 publications trouvées"
                                       style="-fx-font-size:15px;-fx-font-weight:700;-fx-text-fill:#2C3E50;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="✨ Nouvelle publication"
                                        onAction="#handleNewPublication"
                                        style="-fx-background-color:linear-gradient(to right,#F39C12,#E67E22);
                                               -fx-text-fill:white;-fx-font-weight:800;-fx-font-size:13px;
                                               -fx-background-radius:20;-fx-padding:9 20;-fx-cursor:hand;
                                               -fx-effect:dropshadow(gaussian,rgba(243,156,18,0.45),8,0,0,2);"/>
                            </HBox>

                            <!-- Row 2: search field + sort combo -->
                            <HBox spacing="10" alignment="CENTER_LEFT">

                                <!-- Search bar -->
                                <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS"
                                      style="-fx-background-color:#F8FAFC;
                                             -fx-background-radius:25;
                                             -fx-border-color:#E2E8F0;
                                             -fx-border-radius:25;
                                             -fx-padding:0 14;">
                                    <Label text="🔍" style="-fx-font-size:14px;"/>
                                    <TextField fx:id="pubSearchField"
                                               promptText="Rechercher par type, auteur…"
                                               onKeyReleased="#handleSearch"
                                               style="-fx-background-color:transparent;
                                                      -fx-border-width:0;
                                                      -fx-font-size:13px;
                                                      -fx-padding:10 0;
                                                      -fx-prompt-text-fill:#94A3B8;"
                                               HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="btnClearSearch" text="✕"
                                            onAction="#handleClearSearch"
                                            style="-fx-background-color:transparent;
                                                   -fx-text-fill:#94A3B8;-fx-font-size:12px;
                                                   -fx-cursor:hand;-fx-padding:0;"
                                            visible="false" managed="false"/>
                                </HBox>

                                <!-- Sort combo -->
                                <ComboBox fx:id="sortCombo" value="Plus récentes" prefWidth="175"
                                          style="-fx-background-color:white;
                                                 -fx-background-radius:20;
                                                 -fx-border-color:#E2E8F0;
                                                 -fx-border-radius:20;
                                                 -fx-font-size:12px;">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="Plus récentes"/>
                                            <String fx:value="Plus anciennes"/>
                                            <String fx:value="A-Z"/>
                                            <String fx:value="Z-A"/>
                                            <String fx:value="Plus réagies"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                            </HBox>

                        </VBox>

                        <!-- Scrollable publications list -->
                        <ScrollPane fitToWidth="true"
                                    VBox.vgrow="ALWAYS"
                                    style="-fx-background-color: transparent; -fx-border-color: transparent;">

                            <VBox fx:id="publicationsFlowPane"
                                  spacing="20"
                                  alignment="CENTER"
                                  prefWidth="1000"
                                  VBox.vgrow="ALWAYS"/>

                        </ScrollPane>

                    </VBox>
                </HBox>
            </ScrollPane>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- 💬 FLOATING CHAT BUTTON (bottom-right)              -->
            <!-- ═══════════════════════════════════════════════════ -->
            <VBox spacing="12"
                  pickOnBounds="false"
                  StackPane.alignment="BOTTOM_RIGHT">
                <StackPane.margin>
                    <Insets bottom="28" right="28"/>
                </StackPane.margin>

                <!-- 🤖 AI Assistant -->
                <Button onAction="#openChatbot"
                        style="-fx-background-color: linear-gradient(to bottom right, #283593, #1565C0);
                               -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 30; -fx-padding: 12 20; -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(26,35,126,0.5), 12, 0, 0, 3);">
                    <graphic>
                        <Label text="🤖  Assistant IA"
                               style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </graphic>
                </Button>

                <!-- 💬 Community Chat -->
                <Button fx:id="btnOpenChat"
                        onAction="#openGlobalChat"
                        text="💬  Chat"
                        style="-fx-background-color: linear-gradient(to bottom right, #2E7D32, #4CAF50);
                               -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 30; -fx-padding: 12 20; -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(46,125,50,0.5), 12, 0, 0, 3);"/>
            </VBox>

        </StackPane>
    </center>

</BorderPane>