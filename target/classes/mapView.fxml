<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controllers.MapController"
            prefWidth="1000" prefHeight="700"
            style="-fx-background-color: #0f172a;">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- ══════════ HEADER ══════════ -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: linear-gradient(to right, #1e293b, #0f172a);
                     -fx-padding: 16 24;
                     -fx-border-color: #334155; -fx-border-width: 0 0 1 0;">

            <Label text="🗺️" style="-fx-font-size: 26px;"/>
            <VBox spacing="2">
                <Label text="Carte des Trajets RE7LA"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;
                              -fx-text-fill: white;"/>
                <Label text="OpenStreetMap + OSRM · Tunisie"
                       style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Badge statut connexion -->
            <HBox spacing="6" alignment="CENTER"
                  style="-fx-background-color: rgba(16,185,129,0.15);
                         -fx-padding: 6 14; -fx-background-radius: 20;
                         -fx-border-color: rgba(16,185,129,0.3); -fx-border-radius: 20;">
                <Label fx:id="statusDot" text="●"
                       style="-fx-text-fill: #10b981; -fx-font-size: 10px;"/>
                <Label fx:id="statusLabel" text="Connecté"
                       style="-fx-text-fill: #10b981; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </HBox>

            <Button text="✕ Fermer" onAction="#fermer"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 18;
                           -fx-background-radius: 10; -fx-cursor: hand;"/>
        </HBox>

        <!-- ══════════ CORPS : SIDEBAR + CARTE ══════════ -->
        <HBox spacing="0" VBox.vgrow="ALWAYS">

            <!-- ─── PANNEAU GAUCHE ─── -->
            <VBox spacing="0" prefWidth="320" minWidth="300"
                  style="-fx-background-color: #1e293b;
                         -fx-border-color: #334155; -fx-border-width: 0 1 0 0;">

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background: transparent; -fx-background-color: transparent;">
                    <VBox spacing="16"
                          style="-fx-padding: 20;">

                        <!-- ── Sélection itinéraire ── -->
                        <VBox spacing="12"
                              style="-fx-background-color: #0f172a;
                                     -fx-padding: 16; -fx-background-radius: 14;
                                     -fx-border-color: #334155; -fx-border-radius: 14;">

                            <Label text="📍 Calculer un itinéraire"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                                          -fx-text-fill: #e2e8f0;"/>
                            <Separator style="-fx-background-color: #334155;"/>

                            <!-- Départ -->
                            <VBox spacing="5">
                                <Label text="Ville de départ"
                                       style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="🟢" style="-fx-font-size: 12px;"/>
                                    <ComboBox fx:id="mapDepartCombo"
                                              promptText="Choisir..."
                                              maxWidth="Infinity"
                                              HBox.hgrow="ALWAYS"
                                              style="-fx-background-color: #1e293b;
                                                     -fx-text-fill: white;
                                                     -fx-border-color: #334155;
                                                     -fx-border-radius: 8;
                                                     -fx-background-radius: 8;
                                                     -fx-padding: 6 10;"/>
                                </HBox>
                            </VBox>

                            <!-- Flèche séparatrice -->
                            <HBox alignment="CENTER">
                                <Label text="│\n▼"
                                       style="-fx-text-fill: #475569; -fx-font-size: 11px;
                                              -fx-text-alignment: center;"/>
                            </HBox>

                            <!-- Arrivée -->
                            <VBox spacing="5">
                                <Label text="Ville d'arrivée"
                                       style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="🔴" style="-fx-font-size: 12px;"/>
                                    <ComboBox fx:id="mapArriveeCombo"
                                              promptText="Choisir..."
                                              maxWidth="Infinity"
                                              HBox.hgrow="ALWAYS"
                                              style="-fx-background-color: #1e293b;
                                                     -fx-text-fill: white;
                                                     -fx-border-color: #334155;
                                                     -fx-border-radius: 8;
                                                     -fx-background-radius: 8;
                                                     -fx-padding: 6 10;"/>
                                </HBox>
                            </VBox>

                            <!-- Bouton Calculer -->
                            <Button text="🧭  Calculer l'itinéraire"
                                    maxWidth="Infinity"
                                    onAction="#calculerItineraire"
                                    style="-fx-background-color: linear-gradient(to right, #3b82f6, #6366f1);
                                           -fx-text-fill: white; -fx-font-weight: bold;
                                           -fx-font-size: 13px; -fx-padding: 11 0;
                                           -fx-background-radius: 10; -fx-cursor: hand;
                                           -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.4), 10, 0, 0, 3);"/>
                        </VBox>

                        <!-- ── Résultats itinéraire ── -->
                        <VBox fx:id="resultsPanel" spacing="10" visible="false" managed="false"
                              style="-fx-background-color: #0f172a; -fx-padding: 16;
                                     -fx-background-radius: 14;
                                     -fx-border-color: #1d4ed8; -fx-border-radius: 14;">

                            <Label text="📊 Résultats"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                                          -fx-text-fill: #e2e8f0;"/>
                            <Separator style="-fx-background-color: #1e3a5f;"/>

                            <!-- Distance -->
                            <HBox spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color: rgba(59,130,246,0.1);
                                         -fx-padding: 12; -fx-background-radius: 10;">
                                <Label text="📏" style="-fx-font-size: 20px;"/>
                                <VBox spacing="2">
                                    <Label text="Distance" style="-fx-text-fill: #64748b; -fx-font-size: 10px;"/>
                                    <Label fx:id="resultDistance"
                                           text="— km"
                                           style="-fx-font-size: 20px; -fx-font-weight: bold;
                                                  -fx-text-fill: #3b82f6;"/>
                                </VBox>
                            </HBox>

                            <!-- Durée -->
                            <HBox spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color: rgba(16,185,129,0.1);
                                         -fx-padding: 12; -fx-background-radius: 10;">
                                <Label text="⏱️" style="-fx-font-size: 20px;"/>
                                <VBox spacing="2">
                                    <Label text="Durée estimée" style="-fx-text-fill: #64748b; -fx-font-size: 10px;"/>
                                    <Label fx:id="resultDuree"
                                           text="— min"
                                           style="-fx-font-size: 20px; -fx-font-weight: bold;
                                                  -fx-text-fill: #10b981;"/>
                                </VBox>
                            </HBox>

                            <!-- Prix estimé -->
                            <HBox spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color: rgba(245,158,11,0.1);
                                         -fx-padding: 12; -fx-background-radius: 10;">
                                <Label text="💰" style="-fx-font-size: 20px;"/>
                                <VBox spacing="2">
                                    <Label text="Prix estimé (1 DT/km)" style="-fx-text-fill: #64748b; -fx-font-size: 10px;"/>
                                    <Label fx:id="resultPrix"
                                           text="— DT"
                                           style="-fx-font-size: 20px; -fx-font-weight: bold;
                                                  -fx-text-fill: #f59e0b;"/>
                                </VBox>
                            </HBox>

                            <!-- Résumé -->
                            <Label fx:id="resultResume"
                                   wrapText="true"
                                   style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;
                                          -fx-padding: 4 0 0 0;"/>

                            <!-- Bouton appliquer au trajet -->
                            <Button text="✅  Utiliser ces données"
                                    maxWidth="Infinity"
                                    onAction="#utiliserItineraire"
                                    style="-fx-background-color: #10b981;
                                           -fx-text-fill: white; -fx-font-weight: bold;
                                           -fx-padding: 10 0; -fx-background-radius: 10;
                                           -fx-cursor: hand;"/>
                        </VBox>

                        <!-- ── Tous les trajets ── -->
                        <VBox spacing="10"
                              style="-fx-background-color: #0f172a; -fx-padding: 16;
                                     -fx-background-radius: 14;
                                     -fx-border-color: #334155; -fx-border-radius: 14;">
                            <Label text="🛣️ Trajets enregistrés"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                                          -fx-text-fill: #e2e8f0;"/>
                            <Separator style="-fx-background-color: #334155;"/>
                            <VBox fx:id="trajetsListMap" spacing="8"/>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- ─── CARTE (WebView Leaflet) ─── -->
            <StackPane HBox.hgrow="ALWAYS">
                <WebView fx:id="mapWebView"/>

                <!-- Spinner de chargement -->
                <VBox fx:id="loadingOverlay" alignment="CENTER" spacing="12"
                      style="-fx-background-color: rgba(15,23,42,0.85);">
                    <ProgressIndicator fx:id="loadingSpinner"
                                       prefWidth="48" prefHeight="48"
                                       style="-fx-progress-color: #3b82f6;"/>
                    <Label fx:id="loadingLabel" text="Calcul de l'itinéraire..."
                           style="-fx-text-fill: white; -fx-font-size: 14px;
                                  -fx-font-weight: bold;"/>
                </VBox>
            </StackPane>
        </HBox>
    </VBox>
</AnchorPane>
