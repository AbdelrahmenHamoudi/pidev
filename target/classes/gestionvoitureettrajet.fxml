<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="700.0"
            prefWidth="1200.0"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controllers.PageAddVoiture">

    <!-- SIDEBAR -->
    <VBox prefWidth="260" spacing="10" styleClass="sidebar"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0">

        <VBox alignment="CENTER" spacing="15">
            <VBox.margin><Insets top="25.0"/></VBox.margin>
            <ImageView fitHeight="150.0" fitWidth="150.0" preserveRatio="true">
                <Image url="@images/re7la.png"/>
            </ImageView>
        </VBox>

        <Label styleClass="sidebar-title" text="Tableau de bord">
            <VBox.margin><Insets bottom="30.0" left="25.0"/></VBox.margin>
        </Label>

        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" styleClass="sidebar-button" text="👥   Gestion Utilisateurs"/>
        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" styleClass="sidebar-button" text="💳   Gestion des Hébergements"/>
        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" styleClass="sidebar-button" text="💸   Gestion des Activités"/>
        <Button text="🚗 Gestion Voitures" styleClass="sidebar-button"/>
        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" styleClass="sidebar-button" text="🎁   Gestion des Promotions"/>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox spacing="5.0">
            <VBox.margin><Insets bottom="20.0"/></VBox.margin>
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-padding: 0 0 0 20;" text="SYSTÈME"/>
            <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" styleClass="sidebar-button" text="⚙️   Paramètres"/>
            <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" styleClass="sidebar-button" text="🚪   Déconnexion"/>
        </VBox>
    </VBox>

    <!-- MAIN CONTENT -->
    <ScrollPane fx:id="viewVoitures" fitToWidth="true" styleClass="main-scroll-pane"
                AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="260.0"
                AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <VBox spacing="20" styleClass="content-area">

            <!-- ===== HEADER VOITURES ===== -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <VBox>
                    <Label text="Gestion des Voitures" styleClass="header-label"/>
                    <Label text="Gestion complète des voitures et des trajets" styleClass="header-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>

                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="search-box">
                    <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0"/></padding>
                    <Label text="🔍" textFill="#94a3b8"/>
                    <TextField fx:id="searchVoituresField"
                               promptText="Rechercher par marque, modèle..."
                               styleClass="search-field"
                               prefWidth="220"
                               onKeyReleased="#rechercherVoitures"/>
                </HBox>

                <HBox alignment="CENTER" spacing="10.0"
                      style="-fx-background-color: white; -fx-background-radius: 30; -fx-padding: 5 15 5 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);">
                    <Circle fill="#e2e8f0" radius="16.0" stroke="WHITE" strokeType="INSIDE"/>
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #334155; -fx-font-size: 13px;" text="Admin"/>
                </HBox>
            </HBox>

            <!-- ===== STATS VOITURES ===== -->
            <HBox spacing="15.0">
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-hebergement" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 24px; -fx-text-fill: #F7DC6F;" text="🚗"/>
                    <VBox>
                        <Label styleClass="stat-title" text="Voitures"/>
                        <Label fx:id="nbVoituresLabel" styleClass="stat-value" text="0"/>
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-reservations" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 24px; -fx-text-fill: #2C3E50;" text="💰"/>
                    <VBox>
                        <Label styleClass="stat-title" text="Prix Totals"/>
                        <Label fx:id="prixTotalLabel" styleClass="stat-value" text="0"/>
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-disponibles" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 24px; -fx-text-fill: #1ABC9C;" text="📉"/>
                    <VBox>
                        <Label styleClass="stat-title" text="Voitures Disponibles"/>
                        <Label fx:id="disponiblesLabel" styleClass="stat-value" text="0"/>
                    </VBox>
                </HBox>
            </HBox>

            <!-- ===== FORM + TABLE VOITURES ===== -->
            <HBox spacing="25.0">

                <!-- FORM VOITURE -->
                <VBox minWidth="300.0" prefWidth="350.0" spacing="15.0" styleClass="card">
                    <Label styleClass="card-title" text=" Ajouter voiture :"/>
                    <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                        <VBox spacing="6.0" alignment="CENTER">
                            <Label styleClass="form-label" text="Aperçu de l'image"/>
                            <ImageView fitWidth="200" fitHeight="150" preserveRatio="true">
                                <Image url="@images/ajoutervoiture.png"/>
                            </ImageView>
                        </VBox>
                        <VBox spacing="6.0">
                            <Label styleClass="form-label" text="marque *"/>
                            <TextField fx:id="marqueField" promptText="Ex: bmw, Audi..." styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="6.0">
                            <Label styleClass="form-label" text="Modele *"/>
                            <TextField fx:id="modeleField" promptText="Donnez le modele..."/>
                        </VBox>
                        <VBox spacing="6.0">
                            <Label styleClass="form-label" text="Immatriculation *"/>
                            <TextField fx:id="immatriculationField" promptText="EX: 165 TUN 4550 ..."/>
                            <HBox spacing="8.0">
                                <Button fx:id="btnDecodeVin" text="🔍 Décoder VIN" onAction="#decoderVIN" styleClass="vin-button"/>
                                <Button fx:id="btnAfficherPDF" text="📄 VIN Report" styleClass="vin-button-pdf"/>
                            </HBox>

                        </VBox>
                        <GridPane hgap="10.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>
                            <rowConstraints><RowConstraints/></rowConstraints>
                            <VBox spacing="6.0" GridPane.columnIndex="0">
                                <Label styleClass="form-label" text="Prix en KM *"/>
                                <TextField fx:id="prixKmField" promptText="Le Prix ... " styleClass="text-field"/>
                            </VBox>
                            <VBox spacing="6.0" GridPane.columnIndex="1">
                                <Label styleClass="form-label" text="Nombre de Places *"/>
                                <TextField fx:id="nbPlacesField" promptText="Entrez ..." styleClass="text-field"/>
                            </VBox>
                        </GridPane>
                        <GridPane hgap="10.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>
                            <rowConstraints><RowConstraints/></rowConstraints>
                            <VBox spacing="6.0" GridPane.columnIndex="0">
                                <Label styleClass="form-label" text="Avec chauffeur ? *"/>
                                <CheckBox fx:id="avecChauffeurCheck" style="-fx-padding: 8 0 0 0;" text="oui "/>
                            </VBox>
                            <VBox alignment="BOTTOM_LEFT" spacing="6.0" GridPane.columnIndex="1">
                                <Label styleClass="form-label" text="Disponibilité"/>
                                <CheckBox fx:id="disponibiliteCheck" style="-fx-padding: 8 0 0 0;" text="Disponible "/>
                            </VBox>
                        </GridPane>
                        <VBox spacing="6.0">
                            <Label styleClass="form-label" text="Entrer votre description *"/>
                            <TextArea fx:id="descriptionField" promptText="Description ..."/>
                        </VBox>
                        <VBox spacing="6.0">
                            <Label styleClass="form-label" text="Image de la voiture *"/>
                            <HBox spacing="8.0" alignment="CENTER_LEFT">
                                <TextField fx:id="imageField" promptText="Sélectionnez une image"
                                           styleClass="text-field" HBox.hgrow="ALWAYS"/>
                                <Button mnemonicParsing="false" onAction="#parcourirImage"
                                        prefWidth="90.0" styleClass="secondary-button" text="Parcourir"/>
                            </HBox>
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"
                                   text="Formats acceptés: JPG, PNG, GIF (max 5 MB)"/>
                        </VBox>
                    </VBox>
                    <VBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#ajouterVoiture"
                                prefHeight="45.0" styleClass="action-button" text="💾   Enregistrer la voiture"/>
                        <HBox spacing="10.0">
                            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#supprimerVoiture"
                                    prefHeight="40.0" styleClass="delete-button" text=" Supprimer " HBox.hgrow="ALWAYS"/>
                            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#modifierVoiture"
                                    prefHeight="40.0" styleClass="secondary-button" text=" Modifier" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- TABLE VOITURES -->
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="card-title" text="📋 Liste des Voitures"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox spacing="8.0">

                            <Button fx:id="btnPdfVoitures"
                                    mnemonicParsing="false"
                                    styleClass="secondary-button"
                                    text="📄 PDF"
                                    onAction="#exporterPdfVoitures"/>

                            <Button fx:id="btnGestionVoiture" mnemonicParsing="false"
                                    styleClass="secondary-button" text="..."
                                    onAction="#openGestionVoiture"/>
                        </HBox>
                    </HBox>

                    <TableView fx:id="tableVoitures" VBox.vgrow="ALWAYS" prefHeight="300.0">
                        <columns>
                            <TableColumn fx:id="colImage"           text="Image"           prefWidth="100"/>
                            <TableColumn fx:id="colIdVoiture"       text="ID"              prefWidth="45"/>
                            <TableColumn fx:id="colMarque"          text="Marque"          prefWidth="100"/>
                            <TableColumn fx:id="colModele"          text="Modele"          prefWidth="100"/>
                            <TableColumn fx:id="colImmatriculation" text="Immatriculation" prefWidth="130"/>
                            <TableColumn fx:id="colPrixKm"          text="Prix"            prefWidth="75"/>
                            <TableColumn fx:id="colNbPlaces"        text="Places"          prefWidth="60"/>
                            <TableColumn fx:id="colAvecChauffeur"   text="Chauffeur"       prefWidth="80"/>
                            <TableColumn fx:id="colDisponibilite"   text="Disponible"      prefWidth="80"/>
                            <TableColumn fx:id="colDescription"     text="Description"     prefWidth="150"/>
                        </columns>
                    </TableView>

                    <HBox fx:id="paginationContainer" alignment="CENTER_RIGHT" spacing="5.0">
                        <Label fx:id="paginationLabel" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- ===== SÉPARATEUR ===== -->
            <Separator/>

            <!-- ===== HEADER TRAJETS ===== -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <VBox>
                    <Label text="Gestion des Trajets" styleClass="header-label"/>
                    <Label text="Gestion complète des trajets" styleClass="header-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>

                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="search-box">
                    <padding><Insets top="8" bottom="8" left="15" right="15"/></padding>
                    <Label text="🔍" textFill="#94a3b8"/>
                    <TextField fx:id="searchTrajetsField"
                               promptText="Rechercher par départ, arrivée..."
                               styleClass="search-field"
                               prefWidth="220"
                               onKeyReleased="#rechercherTrajets"/>
                </HBox>
            </HBox>

            <!-- ===== STATS TRAJETS ===== -->
            <HBox spacing="15.0">
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-hebergement" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 24px; -fx-text-fill: #F7DC6F;" text="🛣️"/>
                    <VBox>
                        <Label styleClass="stat-title" text="Trajets"/>
                        <Label fx:id="nbTrajetsLabel" text="0"/>
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-reservations" HBox.hgrow="ALWAYS">

                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-disponibles" HBox.hgrow="ALWAYS">

                </HBox>
            </HBox>

            <!-- ===== TABLE TRAJETS ===== -->
            <VBox spacing="10.0" styleClass="card">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="card-title" text="📋 Liste des Trajets"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox spacing="8.0">
                        <Button fx:id="btnPdfTrajets"
                                mnemonicParsing="false"
                                styleClass="secondary-button"
                                text="📄 PDF"
                                onAction="#exporterPdfTrajets"/>
                        <Button fx:id="btnStatistiques" mnemonicParsing="false"
                                styleClass="secondary-button" text="📊 Stats" onAction="#ouvrirStatistiques"/>

                    </HBox>
                </HBox>

                <TableView fx:id="tableTrajets" VBox.vgrow="ALWAYS" prefHeight="300.0">
                    <columns>
                        <TableColumn fx:id="colIdTrajet"    text="ID"        prefWidth="45"/>
                        <TableColumn fx:id="colDepart"      text="Depart"    prefWidth="130"/>
                        <TableColumn fx:id="colArrivee"     text="Arrivee"   prefWidth="130"/>
                        <TableColumn fx:id="colDistance"    text="Distance"  prefWidth="100"/>
                        <TableColumn fx:id="colDate"        text="Date"      prefWidth="110"/>
                        <TableColumn fx:id="colNbPersonnes" text="Personnes" prefWidth="90"/>
                        <TableColumn fx:id="colStatut"      text="Statut"    prefWidth="100"/>
                    </columns>
                </TableView>

                <HBox fx:id="paginationTrajetContainer" alignment="CENTER_RIGHT" spacing="5.0">
                    <Label fx:id="paginationTrajetLabel"
                           style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

        </VBox>
    </ScrollPane>

</AnchorPane>
