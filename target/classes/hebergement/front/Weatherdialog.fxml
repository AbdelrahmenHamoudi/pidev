<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controllers.hebergement.front.WeatherController"
            stylesheets="@StyleWeather.css"
            styleClass="weather-root"
            prefWidth="850" prefHeight="660">

    <!-- ═══════════════════ HEADER ═══════════════════ -->
    <top>
        <VBox styleClass="weather-header" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="🌤" style="-fx-font-size:36px;"/>
                <VBox spacing="3">
                    <Label text="Météo pour votre séjour" styleClass="weather-title"/>
                    <Label fx:id="lblVille" text="📍 Chargement..." styleClass="weather-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox alignment="CENTER_RIGHT" spacing="4">
                    <Label fx:id="lblTypeHeberg" text="🏨 Hébergement" styleClass="type-badge"/>
                    <Label fx:id="lblCoords"     text=""              styleClass="coords-label"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- ═══════════════════ CENTER ═══════════════════ -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color:transparent;-fx-border-color:transparent;">
            <StackPane>

                <!-- SPINNER DE CHARGEMENT -->
                <ProgressIndicator fx:id="loadingSpinner"
                                   prefWidth="80" prefHeight="80"
                                   style="-fx-progress-color:#F39C12;"
                                   StackPane.alignment="CENTER"/>

                <!-- CONTENU PRINCIPAL -->
                <VBox fx:id="contentArea" spacing="16"
                      visible="false" managed="false">
                    <padding><Insets top="20" right="25" bottom="25" left="25"/></padding>

                    <!-- ALERTES INTELLIGENTES -->
                    <HBox fx:id="alerteUVBox" styleClass="alert-box alert-uv"
                          spacing="12" alignment="CENTER_LEFT"
                          visible="false" managed="false">
                        <Label text="☀" style="-fx-font-size:22px;"/>
                        <Label fx:id="alerteUVLabel"
                               text="Indice UV élevé — Pensez à la crème solaire."
                               styleClass="alert-text" wrapText="true"
                               HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox fx:id="alerteMerBox" styleClass="alert-box alert-mer"
                          spacing="12" alignment="CENTER_LEFT"
                          visible="false" managed="false">
                        <Label text="🌊" style="-fx-font-size:22px;"/>
                        <Label fx:id="alerteMerLabel"
                               text="Mer agitée — Baignade déconseillée."
                               styleClass="alert-text" wrapText="true"
                               HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox fx:id="bonTempsBox" styleClass="alert-box alert-bon"
                          spacing="12" alignment="CENTER_LEFT"
                          visible="false" managed="false">
                        <Label text="🌞" style="-fx-font-size:22px;"/>
                        <Label fx:id="bonTempsLabel"
                               text="Conditions idéales pour les activités extérieures !"
                               styleClass="alert-text" wrapText="true"
                               HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- MÉTÉO ACTUELLE -->
                    <HBox spacing="15">
                        <VBox styleClass="weather-card-main" spacing="8"
                              alignment="CENTER" prefWidth="210" minWidth="210">
                            <Label fx:id="lblTempActuelle" text="--°C"
                                   style="-fx-font-size:52px;-fx-font-weight:bold;-fx-text-fill:#F39C12;"/>
                            <Label fx:id="lblCondition" text="--"
                                   style="-fx-font-size:14px;-fx-text-fill:#64748B;"/>
                            <Label text="Maintenant"
                                   style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                        </VBox>
                        <VBox styleClass="weather-card-main" spacing="10"
                              alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                            <HBox spacing="12">
                                <VBox styleClass="detail-chip" spacing="4"
                                      alignment="CENTER" HBox.hgrow="ALWAYS">
                                    <Label text="🔆 Indice UV" styleClass="detail-label"/>
                                    <Label fx:id="lblUV" text="--/11"
                                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#E67E22;"/>
                                </VBox>
                                <VBox styleClass="detail-chip" spacing="4"
                                      alignment="CENTER" HBox.hgrow="ALWAYS">
                                    <Label text="💨 Vent" styleClass="detail-label"/>
                                    <Label fx:id="lblVent" text="-- km/h"
                                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#3498DB;"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="12">
                                <VBox styleClass="detail-chip" spacing="4"
                                      alignment="CENTER" HBox.hgrow="ALWAYS">
                                    <Label text="💧 Humidité" styleClass="detail-label"/>
                                    <Label fx:id="lblHumidite" text="--%"
                                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1ABC9C;"/>
                                </VBox>
                                <VBox styleClass="detail-chip" spacing="4"
                                      alignment="CENTER" HBox.hgrow="ALWAYS">
                                    <Label text="📍 Zone" styleClass="detail-label"/>
                                    <Label fx:id="lblVisibilite" text="Tunisie"
                                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#2C3E50;"
                                           wrapText="true"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- SECTION MARINE (conditionnelle) -->
                    <VBox fx:id="marineSection" styleClass="marine-section" spacing="14"
                          visible="false" managed="false">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="🌊" style="-fx-font-size:22px;"/>
                            <Label text="Conditions Marines" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblEtatMer" text="--"
                                   style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#2980B9;"/>
                        </HBox>
                        <HBox spacing="12">
                            <VBox styleClass="marine-chip" spacing="5"
                                  alignment="CENTER" HBox.hgrow="ALWAYS">
                                <Label text="🌊 Hauteur vagues" styleClass="detail-label"/>
                                <Label fx:id="lblVagues" text="-- m"
                                       style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#2980B9;"/>
                            </VBox>
                            <VBox styleClass="marine-chip" spacing="5"
                                  alignment="CENTER" HBox.hgrow="ALWAYS">
                                <Label text="🌡 Temp. eau" styleClass="detail-label"/>
                                <Label fx:id="lblTempEau" text="--°C"
                                       style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#E74C3C;"/>
                            </VBox>
                            <VBox styleClass="marine-chip" spacing="5"
                                  alignment="CENTER" HBox.hgrow="ALWAYS">
                                <Label text="🏊 Risque baignade" styleClass="detail-label"/>
                                <Label fx:id="lblRisqueBaignade" text="--"
                                       style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#27AE60;"
                                       wrapText="true"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- PRÉVISIONS 14 JOURS -->
                    <VBox styleClass="forecast-section" spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="📅" style="-fx-font-size:20px;"/>
                            <Label text="Prévisions sur 14 jours" styleClass="section-title"/>
                        </HBox>
                        <ScrollPane fitToHeight="true"
                                    hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                                    prefHeight="185"
                                    style="-fx-background-color:transparent;-fx-border-color:transparent;">
                            <HBox fx:id="forecastContainer" spacing="10" alignment="CENTER_LEFT">
                                <padding><Insets top="5" right="5" bottom="5" left="5"/></padding>
                            </HBox>
                        </ScrollPane>
                    </VBox>

                    <!-- RÉSUMÉ IA -->
                    <VBox fx:id="iaSummaryBox" styleClass="ia-summary-box" spacing="10"
                          visible="false" managed="false">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="🤖" style="-fx-font-size:20px;"/>
                            <Label text="Résumé météo par IA"
                                   style="-fx-text-fill:white;-fx-font-size:16px;-fx-font-weight:bold;"/>
                            <Label text="Claude AI"
                                   style="-fx-font-size:10px;-fx-text-fill:#94A3B8;
                                          -fx-background-color:rgba(255,255,255,0.15);
                                          -fx-padding:3 8;-fx-background-radius:10;"/>
                        </HBox>
                        <Label fx:id="lblIASummary"
                               text="Génération en cours..."
                               styleClass="ia-text" wrapText="true"/>
                    </VBox>

                </VBox>
            </StackPane>
        </ScrollPane>
    </center>

    <!-- ═══════════════════ FOOTER ═══════════════════ -->
    <bottom>
        <HBox styleClass="weather-footer" alignment="CENTER_LEFT" spacing="15">
            <Label text="📡 Open-Meteo · OpenStreetMap"
                   style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
            <Label text="•" style="-fx-text-fill:#CBD5E1;"/>
            <Label text="🤖 Claude by Anthropic"
                   style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕  Fermer" onAction="#fermer"
                    style="-fx-background-color:#E2E8F0;-fx-text-fill:#2C3E50;
                           -fx-font-weight:bold;-fx-padding:9 22;
                           -fx-background-radius:15;-fx-cursor:hand;"/>
        </HBox>
    </bottom>

</BorderPane>