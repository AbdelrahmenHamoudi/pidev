<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="680.0" prefWidth="1000.0"
            stylesheets="@StyleAnalyse.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controllers.hebergement.back.AnalyseConcurrentielleController">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- ═══════ HEADER ═══════ -->
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="20">
            <padding><Insets top="20" left="30" right="30" bottom="20"/></padding>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="📊 Analyse Concurrentielle" styleClass="header-title"/>
                <Label text="Comparez vos hébergements avec le marché local tunisien"
                       styleClass="header-sub"/>
            </VBox>
            <Label fx:id="lblSaison" text="–" styleClass="saison-badge"/>
        </HBox>

        <!-- ═══════ BARRE DE SÉLECTION ═══════ -->
        <HBox spacing="15" styleClass="select-bar" alignment="CENTER_LEFT">
            <padding><Insets top="15" left="30" right="30" bottom="15"/></padding>
            <Label text="Hébergement :" styleClass="select-label"/>
            <ComboBox fx:id="comboHebergement"
                      promptText="Choisissez un hébergement à analyser..."
                      styleClass="combo-heberg"
                      HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="btnAnalyser"
                    onAction="#lancerAnalyse"
                    text="🔍  Lancer l'analyse"
                    styleClass="btn-analyser"/>
            <ProgressIndicator fx:id="progressAnalyse" visible="false"/>
        </HBox>

        <!-- Statut -->
        <Label fx:id="lblStatut"
               text="Sélectionnez un hébergement et lancez l'analyse"
               styleClass="statut-label">
            <padding><Insets top="5" left="30" bottom="5"/></padding>
        </Label>

        <!-- ═══════ PANNEAU RÉSULTAT (caché par défaut) ═══════ -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="result-scroll">
            <VBox fx:id="panneauResultat" spacing="20" visible="false">
                <padding><Insets top="15" left="30" right="30" bottom="30"/></padding>

                <!-- ── LIGNE 1 : 3 cartes KPI ── -->
                <HBox spacing="15">

                    <!-- Carte : Votre hébergement -->
                    <VBox styleClass="kpi-card card-admin" spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="🏠  Votre hébergement" styleClass="kpi-card-title"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="📍 Ville :" styleClass="kpi-key"/>
                            <Label fx:id="lblVille" text="–" styleClass="kpi-val-main"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="🏷 Type :" styleClass="kpi-key"/>
                            <Label fx:id="lblType" text="–" styleClass="kpi-val"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="💰 Prix :" styleClass="kpi-key"/>
                            <Label fx:id="lblPrixAdmin" text="–" styleClass="kpi-val-money"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="📊 Occupation :" styleClass="kpi-key"/>
                            <Label fx:id="lblOccupationAdmin" text="–" styleClass="kpi-val"/>
                        </HBox>
                    </VBox>

                    <!-- Carte : Marché local -->
                    <VBox styleClass="kpi-card card-marche" spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="🌍  Marché local (référence)" styleClass="kpi-card-title"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="💰 Prix moyen :" styleClass="kpi-key"/>
                            <Label fx:id="lblPrixMarche" text="–" styleClass="kpi-val-money"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="📊 Taux d'occup. :" styleClass="kpi-key"/>
                            <Label fx:id="lblOccupationMarche" text="–" styleClass="kpi-val"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="💵 Revenu/mois :" styleClass="kpi-key"/>
                            <Label fx:id="lblRevenuMarche" text="–" styleClass="kpi-val-money"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="🌟 Attractivité :" styleClass="kpi-key"/>
                            <Label fx:id="lblAttractiv" text="–" styleClass="kpi-val"/>
                        </HBox>
                    </VBox>

                    <!-- Carte : Résultat comparatif -->
                    <VBox styleClass="kpi-card card-compare" spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="⚖️  Comparatif" styleClass="kpi-card-title"/>

                        <VBox spacing="5" styleClass="compare-block">
                            <Label text="PRIX" styleClass="compare-sub"/>
                            <Label fx:id="lblBadgePrix" text="–" styleClass="badge"/>
                            <Label fx:id="lblEcartPrix" text="–" styleClass="ecart-label"/>
                        </VBox>

                        <VBox spacing="5" styleClass="compare-block">
                            <Label text="OCCUPATION" styleClass="compare-sub"/>
                            <Label fx:id="lblBadgeOccupation" text="–" styleClass="badge"/>
                            <Label fx:id="lblEcartOccupation" text="–" styleClass="ecart-label"/>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- ── LIGNE 2 : Analyse IA ── -->
                <VBox styleClass="ia-card" spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🤖  Analyse IA – Recommandations stratégiques"
                               styleClass="ia-card-title" HBox.hgrow="ALWAYS"/>
                        <Label text="Groq AI · LLaMA 3.3 70B" styleClass="ia-badge"/>
                    </HBox>
                    <TextArea fx:id="txtAnalyseIA"
                              prefHeight="280"
                              wrapText="true"
                              editable="false"
                              styleClass="ia-textarea"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>