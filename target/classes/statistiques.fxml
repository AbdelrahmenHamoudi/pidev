<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controllers.StatistiquesController"
            prefWidth="1100" prefHeight="750"
            style="-fx-background-color: #0f172a;">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- ══════════ HEADER ══════════ -->
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #1e293b;
                     -fx-padding: 14 24;
                     -fx-border-color: #334155; -fx-border-width: 0 0 1 0;">

            <Label text="📊" style="-fx-font-size: 24px;"/>
            <VBox spacing="1">
                <Label text="Tableau de Bord — Statistiques"
                       style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="RE7LA · Voitures &amp; Trajets"
                       style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- ── KPI Cards ── -->
            <HBox spacing="12" alignment="CENTER">

                <!-- Voitures -->
                <VBox alignment="CENTER" spacing="2"
                      style="-fx-background-color: rgba(59,130,246,0.1);
                             -fx-padding: 10 18; -fx-background-radius: 12;
                             -fx-border-color: rgba(59,130,246,0.25); -fx-border-radius: 12;">
                    <Label text="🚗 Voitures"
                           style="-fx-font-size: 10px; -fx-text-fill: #64748b;"/>
                    <Label fx:id="kpiVoituresLabel" text="—"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
                </VBox>

                <!-- Trajets -->
                <VBox alignment="CENTER" spacing="2"
                      style="-fx-background-color: rgba(16,185,129,0.1);
                             -fx-padding: 10 18; -fx-background-radius: 12;
                             -fx-border-color: rgba(16,185,129,0.25); -fx-border-radius: 12;">
                    <Label text="🛣️ Trajets"
                           style="-fx-font-size: 10px; -fx-text-fill: #64748b;"/>
                    <Label fx:id="kpiTrajetsLabel" text="—"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                </VBox>

                <!-- Revenus -->
                <VBox alignment="CENTER" spacing="2"
                      style="-fx-background-color: rgba(245,158,11,0.1);
                             -fx-padding: 10 18; -fx-background-radius: 12;
                             -fx-border-color: rgba(245,158,11,0.25); -fx-border-radius: 12;">
                    <Label text="💰 Revenus"
                           style="-fx-font-size: 10px; -fx-text-fill: #64748b;"/>
                    <Label fx:id="kpiRevenusLabel" text="—"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                </VBox>

                <!-- Disponibles -->
                <VBox alignment="CENTER" spacing="2"
                      style="-fx-background-color: rgba(139,92,246,0.1);
                             -fx-padding: 10 18; -fx-background-radius: 12;
                             -fx-border-color: rgba(139,92,246,0.25); -fx-border-radius: 12;">
                    <Label text="✅ Disponibles"
                           style="-fx-font-size: 10px; -fx-text-fill: #64748b;"/>
                    <Label fx:id="kpiDispoLabel" text="—"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #8b5cf6;"/>
                </VBox>

            </HBox>

            <Separator orientation="VERTICAL"
                       style="-fx-background-color: #334155; -fx-pref-height: 36;"/>

            <Button text="✕ Fermer" onAction="#fermer"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 18;
                           -fx-background-radius: 10; -fx-cursor: hand;"/>
        </HBox>

        <!-- ══════════ CHARTS WEBVIEW ══════════ -->
        <WebView fx:id="chartsWebView" VBox.vgrow="ALWAYS"/>

    </VBox>
</AnchorPane>
