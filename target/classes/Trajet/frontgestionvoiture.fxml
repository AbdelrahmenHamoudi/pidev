<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>


<AnchorPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controllers.Trajet.FrontController"
            stylesheets="@re7la-styles.css">

    <BorderPane styleClass="front-container"
                AnchorPane.topAnchor="0"
                AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0"
                AnchorPane.rightAnchor="0">

        <!-- ================= HEADER ================= -->
        <top>
            <VBox styleClass="front-header" spacing="15">
                <HBox alignment="CENTER" spacing="20">

                    <!-- Logo -->
                    <ImageView fitWidth="90" preserveRatio="true">
                        <Image url="@images/re7la.png"/>
                    </ImageView>

                    <!-- Titre -->
                    <VBox spacing="5">
                        <Text text="RE7LA" styleClass="front-title"/>
                        <Text text="Trouvez votre voiture ou votre trajet idéal"
                              styleClass="front-subtitle"/>
                    </VBox>

                    <!-- Spacer -->
                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- ── Navigation Tabs (Voitures / Trajets) ── -->
                    <HBox spacing="8" alignment="CENTER"
                          style="-fx-background-color: rgba(255,255,255,0.12);
                                 -fx-background-radius: 25;
                                 -fx-padding: 5 8;">
                        <Button fx:id="btnVoitures"
                                text="🚗 Voitures"
                                styleClass="btn-primary"
                                onAction="#showVoituresSection"/>
                        <Button fx:id="btnTrajets"
                                text="🗺️ Trajets"
                                styleClass="btn-secondary"
                                onAction="#showTrajetsSection"/>
                    </HBox>

                    <!-- ── Séparateur ── -->
                    <Separator orientation="VERTICAL"
                               style="-fx-background-color: rgba(255,255,255,0.3); -fx-pref-height: 32;"/>


                    <!-- ── Séparateur ── -->
                    <Separator orientation="VERTICAL"
                               style="-fx-background-color: rgba(255,255,255,0.3); -fx-pref-height: 32;"/>
                    <!-- Dans le header, après le nom utilisateur -->
                    <Button fx:id="btnAccueil" text="🏠 Accueil" styleClass="btn-secondary" onAction="#goToAccueil"/>
                    <Button fx:id="btnProfil" text="👤 Profil" styleClass="btn-secondary" onAction="#goToProfil"/>

                </HBox>

                <!-- ── Search Bar ── -->
                <HBox spacing="12" alignment="CENTER">
                    <TextField fx:id="searchVoituresField"
                               promptText="🔍 Rechercher par marque, modèle ou ville..."
                               styleClass="search-box"
                               HBox.hgrow="ALWAYS"/>
                    <Button text="Rechercher"
                            styleClass="btn-primary"
                            onAction="#searchVoitures"/>
                </HBox>
            </VBox>
        </top>

        <!-- ================= CENTER ================= -->
        <center>
            <ScrollPane fitToWidth="true"
                        fitToHeight="true"
                        pannable="true"
                        styleClass="main-scroll">

                <HBox spacing="25">
                    <padding>
                        <Insets top="25" right="25" bottom="25" left="25"/>
                    </padding>

                    <!-- ================= SIDEBAR ================= -->
                    <VBox styleClass="filter-box" spacing="20" prefWidth="280" maxWidth="280">
                        <Text text="🔎 Filtres" styleClass="filter-title"/>
                        <Separator/>

                        <!-- PANEL FILTRES VOITURES — visible par défaut -->
                        <VBox fx:id="filtresVoituresPanel" spacing="12" visible="true" managed="true">

                            <Label text="🚗 Voitures" styleClass="filter-label"
                                   style="-fx-font-weight: bold; -fx-font-size: 14px;"/>

                            <VBox spacing="6">
                                <Label text="Prix / km" styleClass="filter-label"/>
                                <ComboBox fx:id="filterPrixCombo"
                                          promptText="Tous les prix"
                                          styleClass="filter-combo"
                                          maxWidth="Infinity"/>
                            </VBox>

                            <VBox spacing="6">
                                <Label text="Nombre de places" styleClass="filter-label"/>
                                <ComboBox fx:id="filterPlacesCombo"
                                          promptText="Toutes les places"
                                          styleClass="filter-combo"
                                          maxWidth="Infinity"/>
                            </VBox>

                            <VBox spacing="6">
                                <Label text="Trier par" styleClass="filter-label"/>
                                <ComboBox fx:id="sortVoituresCombo"
                                          promptText="Trier par"
                                          styleClass="filter-combo"
                                          maxWidth="Infinity"/>
                            </VBox>

                            <Separator/>

                            <Button fx:id="btnResetVoitures"
                                    text="🔄 Réinitialiser"
                                    onAction="#resetFiltresVoitures"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #6b7280; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-background-radius: 10;
                                           -fx-cursor: hand; -fx-padding: 9 14;"/>
                        </VBox>

                        <!-- PANEL FILTRES TRAJETS — caché par défaut -->
                        <VBox fx:id="filtresTrajetsPanel" spacing="12" visible="false" managed="false">

                            <Label text="🗺️ Trajets" styleClass="filter-label"
                                   style="-fx-font-weight: bold; -fx-font-size: 14px;"/>

                            <VBox spacing="6">
                                <Label text="Ville de départ" styleClass="filter-label"/>
                                <ComboBox fx:id="departCombo"
                                          promptText="📍 Ville de départ"
                                          styleClass="filter-combo"
                                          maxWidth="Infinity"/>
                            </VBox>

                            <VBox spacing="6">
                                <Label text="Ville d'arrivée" styleClass="filter-label"/>
                                <ComboBox fx:id="arriveeCombo"
                                          promptText="📍 Destination"
                                          styleClass="filter-combo"
                                          maxWidth="Infinity"/>
                            </VBox>

                            <VBox spacing="6">
                                <Label text="Date" styleClass="filter-label"/>
                                <DatePicker fx:id="dateTrajetPicker"
                                            promptText="📅 Date"
                                            styleClass="date-picker"
                                            maxWidth="Infinity"/>
                            </VBox>

                            <VBox spacing="6">
                                <Label text="Personnes" styleClass="filter-label"/>
                                <Spinner fx:id="nbPersonnesSpinner"
                                         prefWidth="120"
                                         styleClass="spinner"/>
                            </VBox>

                            <VBox spacing="6">
                                <Label text="Trier par" styleClass="filter-label"/>
                                <ComboBox fx:id="sortTrajetsCombo"
                                          promptText="Trier par date"
                                          styleClass="filter-combo"
                                          maxWidth="Infinity"/>
                            </VBox>

                            <Button text="🔍 Rechercher trajets"
                                    styleClass="btn-primary"
                                    maxWidth="Infinity"
                                    onAction="#searchTrajets"/>

                            <Separator/>

                            <Button fx:id="btnResetTrajets"
                                    text="🔄 Réinitialiser"
                                    onAction="#resetFiltresTrajets"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #6b7280; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-background-radius: 10;
                                           -fx-cursor: hand; -fx-padding: 9 14;"/>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <!-- ================= MAIN CONTENT ================= -->
                    <VBox spacing="20" HBox.hgrow="ALWAYS">

                        <!-- SECTION VOITURES -->
                        <VBox fx:id="voituresSection" spacing="20">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Text text="Voitures Disponibles"
                                      style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-fill: #0F172A;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <GridPane fx:id="voituresGrid" hgap="25" vgap="25" alignment="TOP_LEFT"/>

                            <HBox spacing="10" alignment="CENTER" style="-fx-padding: 15 0;">
                                <Button text="◀ Précédent" styleClass="btn-secondary" onAction="#previousPageVoitures"/>
                                <Label fx:id="pageVoituresLabel" text="1"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold;
                                              -fx-text-fill: #2C3E50; -fx-padding: 5 20;
                                              -fx-background-color: white; -fx-background-radius: 8;
                                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 4, 0, 0, 2);"/>
                                <Button text="Suivant ▶" styleClass="btn-secondary" onAction="#nextPageVoitures"/>
                            </HBox>
                        </VBox>

                        <!-- SECTION TRAJETS -->
                        <VBox fx:id="trajetsSection" spacing="20" visible="false" managed="false">

                            <VBox styleClass="filter-box" spacing="15">
                                <Text text="➕ Gérer un Trajet" styleClass="filter-title"/>
                                <Separator/>

                                <HBox spacing="15" alignment="CENTER_LEFT">
                                    <VBox spacing="5">
                                        <Label text="Départ" styleClass="filter-label"/>
                                        <ComboBox fx:id="cbDepart" promptText="📍 Ville de départ"
                                                  styleClass="filter-combo" prefWidth="160"/>
                                    </VBox>
                                    <VBox spacing="5">
                                        <Label text="Arrivée" styleClass="filter-label"/>
                                        <ComboBox fx:id="cbArrivee" promptText="📍 Ville d'arrivée"
                                                  styleClass="filter-combo" prefWidth="160"/>
                                    </VBox>
                                    <VBox spacing="5">
                                        <Label text="Date" styleClass="filter-label"/>
                                        <DatePicker fx:id="dpDate" promptText="📅 Date"
                                                    styleClass="date-picker" prefWidth="155"/>
                                    </VBox>
                                    <VBox spacing="5">
                                        <Label text="Personnes" styleClass="filter-label"/>
                                        <Spinner fx:id="spNbPersonnes" prefWidth="90" styleClass="spinner"/>
                                    </VBox>
                                    <VBox spacing="5">
                                        <Label text="Distance (km)" styleClass="filter-label"/>
                                        <TextField fx:id="tfDistance" promptText="km"
                                                   styleClass="search-box" prefWidth="95"/>
                                    </VBox>
                                </HBox>

                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Button fx:id="btnAjouterTrajet" text="➕ Ajouter"
                                            styleClass="btn-primary" onAction="#ajouterTrajetAction"/>
                                    <Button fx:id="btnModifierTrajet" text="✏️ Modifier"
                                            onAction="#modifierTrajet"
                                            style="-fx-background-color: #F39C12; -fx-text-fill: white;
                                                   -fx-font-weight: bold; -fx-padding: 10 20;
                                                   -fx-background-radius: 15; -fx-cursor: hand;
                                                   -fx-effect: dropshadow(gaussian, rgba(243,156,18,0.4), 8, 0, 0, 2);"/>
                                    <Button fx:id="btnSupprimerTrajet" text="🗑️ Supprimer"
                                            onAction="#supprimerTrajet"
                                            style="-fx-background-color: #E74C3C; -fx-text-fill: white;
                                                   -fx-font-weight: bold; -fx-padding: 10 20;
                                                   -fx-background-radius: 15; -fx-cursor: hand;
                                                   -fx-effect: dropshadow(gaussian, rgba(231,76,60,0.4), 8, 0, 0, 2);"/>
                                    <Button fx:id="btnOuvrirCarte"
                                            text="🗺️ Voir sur la carte"
                                            onAction="#ouvrirCarte"
                                            style="-fx-background-color: linear-gradient(to right, #0ea5e9, #3b82f6);
                                                   -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;
                                                   -fx-padding: 10 20; -fx-background-radius: 15; -fx-cursor: hand;
                                                   -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.45), 10, 0, 0, 3);"/>
                                </HBox>
                            </VBox>

                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Text text="Trajets Disponibles"
                                      style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-fill: #0F172A;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <VBox fx:id="trajetsListContainer" spacing="15"/>

                            <HBox spacing="10" alignment="CENTER" style="-fx-padding: 15 0;">
                                <Button text="◀ Précédent" styleClass="btn-secondary" onAction="#previousPageTrajets"/>
                                <Label fx:id="pageTrajetsLabel" text="1"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold;
                                              -fx-text-fill: #2C3E50; -fx-padding: 5 20;
                                              -fx-background-color: white; -fx-background-radius: 8;
                                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 4, 0, 0, 2);"/>
                                <Button text="Suivant ▶" styleClass="btn-secondary" onAction="#nextPageTrajets"/>
                            </HBox>
                        </VBox>

                    </VBox>
                </HBox>
            </ScrollPane>
        </center>

    </BorderPane>

    <!-- ═══════════════════════════════════════════════════════════
         🤖 BOUTON ASSISTANT IA FLOTTANT
         Ancré en bas à droite, toujours visible sur toutes les pages
    ════════════════════════════════════════════════════════════════ -->

    <!-- Tooltip label qui apparaît au survol -->
    <Label fx:id="fabTooltip"
           text="Assistant IA"
           visible="false"
           mouseTransparent="true"
           AnchorPane.bottomAnchor="95"
           AnchorPane.rightAnchor="90"
           style="-fx-background-color: #1e1b4b;
                  -fx-text-fill: white;
                  -fx-font-size: 12px;
                  -fx-font-weight: bold;
                  -fx-padding: 6 12;
                  -fx-background-radius: 8;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 8, 0, 0, 2);"/>

    <!-- Anneau de pulsation (décoratif) -->
    <Button mouseTransparent="true"
            AnchorPane.bottomAnchor="20"
            AnchorPane.rightAnchor="20"
            prefWidth="68" prefHeight="68"
            style="-fx-background-color: rgba(99,102,241,0.25);
                   -fx-background-radius: 50%;
                   -fx-border-color: rgba(99,102,241,0.4);
                   -fx-border-radius: 50%;
                   -fx-border-width: 2;"/>

    <!-- Bouton principal FAB -->
    <Button fx:id="btnAssistantFlottant"
            text="🤖"
            onAction="#openAssistantVocal"
            onMouseEntered="#fabMouseEntered"
            onMouseExited="#fabMouseExited"
            AnchorPane.bottomAnchor="26"
            AnchorPane.rightAnchor="26"
            prefWidth="56" prefHeight="56"
            style="-fx-background-color: linear-gradient(to bottom right, #6366F1, #8B5CF6);
                   -fx-text-fill: white;
                   -fx-font-size: 22px;
                   -fx-background-radius: 50%;
                   -fx-cursor: hand;
                   -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.7), 16, 0, 0, 4);
                   -fx-border-color: rgba(255,255,255,0.2);
                   -fx-border-radius: 50%;
                   -fx-border-width: 2;"/>

</AnchorPane>
