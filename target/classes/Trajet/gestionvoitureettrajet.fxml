<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="700.0" prefWidth="1200.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.Controllers.Trajet.PageAddVoiture">

    <!-- SIDEBAR -->
    <VBox prefWidth="260" spacing="10" styleClass="sidebar" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0">

        <VBox alignment="CENTER" spacing="15">
            <VBox.margin><Insets top="25.0" /></VBox.margin>
            <ImageView fitHeight="150.0" fitWidth="150.0" preserveRatio="true">
                <Image url="@images/re7la.png" />
            </ImageView>
        </VBox>

        <Label styleClass="sidebar-title" text="Tableau de bord">
            <VBox.margin><Insets bottom="30.0" left="25.0" /></VBox.margin>
        </Label>

        <!-- ✅ BOUTONS AVEC onAction -->
        <Button fx:id="btnGestionUtilisateurs" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleShowUsers" styleClass="sidebar-button" text="👥   Gestion Utilisateurs" />
        <Button fx:id="btnGestionHebergement" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleShowHebergements" styleClass="sidebar-button" text="💳   Gestion des Hébergements" />
        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleShowActivites" styleClass="sidebar-button" text="💸   Gestion des Activités" />
        <Button fx:id="btnGestionVoiture" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#openGestionVoiture" styleClass="sidebar-button" text="🚗   Gestion Voitures" />
        <Button fx:id="btnCommunaute" alignment="BASELINE_LEFT" maxWidth="Infinity"
                mnemonicParsing="false" onAction="#handleShowCommunaute" styleClass="sidebar-button"
                text="💬   Gestion Communauté" />
        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleShowPromotions" styleClass="sidebar-button" text="🎁   Gestion des Promotions" />

        <Region VBox.vgrow="ALWAYS" />

        <VBox spacing="5.0">
            <VBox.margin><Insets bottom="20.0" /></VBox.margin>
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-padding: 0 0 0 20;" text="SYSTÈME" />
            <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleShowSettings" styleClass="sidebar-button" text="⚙️   Paramètres" />
            <Button fx:id="btnDeconnexion" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-button" text="🚪   Déconnexion" />
        </VBox>
    </VBox>

    <!-- MAIN CONTENT -->
    <ScrollPane fx:id="viewVoitures" fitToWidth="true" styleClass="main-scroll-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="260.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <VBox spacing="20" styleClass="content-area">

            <!-- ===== HEADER VOITURES ===== -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <VBox>
                    <Label styleClass="header-label" text="Gestion des Voitures" />
                    <Label styleClass="header-subtitle" text="Gestion complète des voitures et des trajets" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="search-box">
                    <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                    <Label text="🔍" textFill="#94a3b8" />
                    <TextField fx:id="searchVoituresField" onKeyReleased="#rechercherVoitures" prefWidth="220" promptText="Rechercher par marque, modèle..." styleClass="search-field" />
                </HBox>

                <!-- ✅ ADMIN PROFILE AVEC BADGE NOTIFICATION -->
                <HBox alignment="CENTER" spacing="10.0" styleClass="profile-chip">
                    <Circle fill="#e2e8f0" radius="16.0" stroke="WHITE" strokeType="INSIDE" />
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #334155; -fx-font-size: 13px;" text="Admin" />
                    <StackPane>
                        <Button fx:id="btnNotifications" onAction="#handleViewNotifications" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px;" text="🔔" />
                        <Label fx:id="notificationBadge" managed="false" style="-fx-background-color: #E74C3C; -fx-text-fill: white;                                       -fx-background-radius: 10; -fx-padding: 2 5; -fx-font-size: 10px;                                       -fx-font-weight: bold; -fx-min-width: 18; -fx-alignment: center;" text="0" visible="false" StackPane.alignment="TOP_RIGHT" />
                    </StackPane>
                </HBox>
            </HBox>

            <!-- ===== STATS VOITURES ===== -->
            <HBox spacing="15.0">
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-hebergement" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 24px; -fx-text-fill: #F7DC6F;" text="🚗" />
                    <VBox>
                        <Label styleClass="stat-title" text="Voitures" />
                        <Label fx:id="nbVoituresLabel" styleClass="stat-value" text="0" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-reservations" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 24px; -fx-text-fill: #2C3E50;" text="💰" />
                    <VBox>
                        <Label styleClass="stat-title" text="Prix Totals" />
                        <Label fx:id="prixTotalLabel" styleClass="stat-value" text="0" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-disponibles" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 24px; -fx-text-fill: #1ABC9C;" text="📉" />
                    <VBox>
                        <Label styleClass="stat-title" text="Voitures Disponibles" />
                        <Label fx:id="disponiblesLabel" styleClass="stat-value" text="0" />
                    </VBox>
                </HBox>
            </HBox>

            <!-- ===== FORM + TABLE VOITURES ===== -->
            <HBox spacing="25.0">

                <!-- FORM VOITURE -->
                <VBox minWidth="300.0" prefWidth="350.0" spacing="15.0" styleClass="card">
                    <Label styleClass="card-title" text=" Ajouter voiture :" />
                    <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                        <VBox alignment="CENTER" spacing="6.0">
                            <Label styleClass="form-label" text="Aperçu de l'image" />
                            <ImageView fitHeight="150" fitWidth="200" preserveRatio="true">
                                <Image url="@images/ajoutervoiture.png" />
                            </ImageView>
                        </VBox>
                        <VBox spacing="6.0">
                            <Label styleClass="form-label" text="marque *" />
                            <TextField fx:id="marqueField" promptText="Ex: bmw, Audi..." styleClass="text-field" />
                        </VBox>
                        <VBox spacing="6.0">
                            <Label styleClass="form-label" text="Modele *" />
                            <TextField fx:id="modeleField" promptText="Donnez le modele..." />
                        </VBox>
                        <VBox spacing="6.0">
                            <Label styleClass="form-label" text="Immatriculation *" />
                            <TextField fx:id="immatriculationField" promptText="EX: 165 TUN 4550 ..." />
                            <HBox spacing="8.0">
                                <Button fx:id="btnDecodeVin" onAction="#decoderVIN" styleClass="vin-button" text="🔍 Décoder VIN" />
                                <Button fx:id="btnAfficherPDF" onAction="#ouvrirPDF" styleClass="vin-button-pdf" text="📄 VIN Report" />
                            </HBox>
                        </VBox>
                        <GridPane hgap="10.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" />
                                <ColumnConstraints percentWidth="50" />
                            </columnConstraints>
                            <rowConstraints><RowConstraints /></rowConstraints>
                            <VBox spacing="6.0" GridPane.columnIndex="0">
                                <Label styleClass="form-label" text="Prix en KM *" />
                                <TextField fx:id="prixKmField" promptText="Le Prix ... " styleClass="text-field" />
                            </VBox>
                            <VBox spacing="6.0" GridPane.columnIndex="1">
                                <Label styleClass="form-label" text="Nombre de Places *" />
                                <TextField fx:id="nbPlacesField" promptText="Entrez ..." styleClass="text-field" />
                            </VBox>
                        </GridPane>
                        <GridPane hgap="10.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" />
                                <ColumnConstraints percentWidth="50" />
                            </columnConstraints>
                            <rowConstraints><RowConstraints /></rowConstraints>
                            <VBox spacing="6.0" GridPane.columnIndex="0">
                                <Label styleClass="form-label" text="Avec chauffeur ? *" />
                                <CheckBox fx:id="avecChauffeurCheck" style="-fx-padding: 8 0 0 0;" text="oui " />
                            </VBox>
                            <VBox alignment="BOTTOM_LEFT" spacing="6.0" GridPane.columnIndex="1">
                                <Label styleClass="form-label" text="Disponibilité" />
                                <CheckBox fx:id="disponibiliteCheck" style="-fx-padding: 8 0 0 0;" text="Disponible " />
                            </VBox>
                        </GridPane>
                        <VBox spacing="6.0">
                            <Label styleClass="form-label" text="Entrer votre description *" />
                            <TextArea fx:id="descriptionField" promptText="Description ..." />
                        </VBox>
                        <VBox spacing="6.0">
                            <Label styleClass="form-label" text="Image de la voiture *" />
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <TextField fx:id="imageField" promptText="Sélectionnez une image" styleClass="text-field" HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#parcourirImage" prefWidth="90.0" styleClass="secondary-button" text="Parcourir" />
                            </HBox>
                            <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" text="Formats acceptés: JPG, PNG, GIF (max 5 MB)" />
                        </VBox>
                    </VBox>
                    <VBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#ajouterVoiture" prefHeight="45.0" styleClass="action-button" text="💾   Enregistrer la voiture" />
                        <HBox spacing="10.0">
                            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#supprimerVoiture" prefHeight="40.0" styleClass="delete-button" text=" Supprimer " HBox.hgrow="ALWAYS" />
                            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#modifierVoiture" prefHeight="40.0" styleClass="secondary-button" text=" Modifier" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                </VBox>

                <!-- TABLE VOITURES -->
                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="card-title" text="📋 Liste des Voitures" />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox spacing="8.0">
                            <Button fx:id="btnPdfVoitures" mnemonicParsing="false" onAction="#exporterPdfVoitures" styleClass="secondary-button" text="📄 PDF" />
                            <!-- ✅ BOUTON SUPPRIMÉ ICI (déjà dans la sidebar) -->
                        </HBox>
                    </HBox>

                    <TableView fx:id="tableVoitures" prefHeight="300.0" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colImage" prefWidth="100" text="Image" />
                            <TableColumn fx:id="colIdVoiture" prefWidth="45" text="ID" />
                            <TableColumn fx:id="colMarque" prefWidth="100" text="Marque" />
                            <TableColumn fx:id="colModele" prefWidth="100" text="Modele" />
                            <TableColumn fx:id="colImmatriculation" prefWidth="130" text="Immatriculation" />
                            <TableColumn fx:id="colPrixKm" prefWidth="75" text="Prix" />
                            <TableColumn fx:id="colNbPlaces" prefWidth="60" text="Places" />
                            <TableColumn fx:id="colAvecChauffeur" prefWidth="80" text="Chauffeur" />
                            <TableColumn fx:id="colDisponibilite" prefWidth="80" text="Disponible" />
                            <TableColumn fx:id="colDescription" prefWidth="150" text="Description" />
                        </columns>
                    </TableView>

                    <HBox fx:id="paginationContainer" alignment="CENTER_RIGHT" spacing="5.0">
                        <Label fx:id="paginationLabel" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" />
                        <Region HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>
            </HBox>

            <!-- ===== SÉPARATEUR ===== -->
            <Separator />

            <!-- ===== HEADER TRAJETS ===== -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <VBox>
                    <Label styleClass="header-label" text="Gestion des Trajets" />
                    <Label styleClass="header-subtitle" text="Gestion complète des trajets" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="search-box">
                    <padding><Insets bottom="8" left="15" right="15" top="8" /></padding>
                    <Label text="🔍" textFill="#94a3b8" />
                    <TextField fx:id="searchTrajetsField" onKeyReleased="#rechercherTrajets" prefWidth="220" promptText="Rechercher par départ, arrivée..." styleClass="search-field" />
                </HBox>
            </HBox>

            <!-- ===== STATS TRAJETS ===== -->
            <HBox spacing="15.0">
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-hebergement" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 24px; -fx-text-fill: #F7DC6F;" text="🛣️" />
                    <VBox>
                        <Label styleClass="stat-title" text="Trajets" />
                        <Label fx:id="nbTrajetsLabel" text="0" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-reservations" HBox.hgrow="ALWAYS">
                    <!-- STATS TRAJETS (peut être ajouté plus tard) -->
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-disponibles" HBox.hgrow="ALWAYS">
                    <!-- STATS TRAJETS (peut être ajouté plus tard) -->
                </HBox>
            </HBox>

            <!-- ===== TABLE TRAJETS ===== -->
            <VBox spacing="10.0" styleClass="card">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="card-title" text="📋 Liste des Trajets" />
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox spacing="8.0">
                        <Button fx:id="btnPdfTrajets" mnemonicParsing="false" onAction="#exporterPdfTrajets" styleClass="secondary-button" text="📄 PDF" />
                        <Button fx:id="btnStatistiques" mnemonicParsing="false" onAction="#ouvrirStatistiques" styleClass="secondary-button" text="📊 Stats" />
                    </HBox>
                </HBox>

                <TableView fx:id="tableTrajets" prefHeight="300.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdTrajet" prefWidth="45" text="ID" />
                        <TableColumn fx:id="colDepart" prefWidth="130" text="Depart" />
                        <TableColumn fx:id="colArrivee" prefWidth="130" text="Arrivee" />
                        <TableColumn fx:id="colDistance" prefWidth="100" text="Distance" />
                        <TableColumn fx:id="colDate" prefWidth="110" text="Date" />
                        <TableColumn fx:id="colNbPersonnes" prefWidth="90" text="Personnes" />
                        <TableColumn fx:id="colStatut" prefWidth="100" text="Statut" />
                    </columns>
                </TableView>

                <HBox fx:id="paginationTrajetContainer" alignment="CENTER_RIGHT" spacing="5.0">
                    <Label fx:id="paginationTrajetLabel" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" />
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

        </VBox>
    </ScrollPane>

</AnchorPane>
