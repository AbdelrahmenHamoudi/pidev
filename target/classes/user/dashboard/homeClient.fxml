                                    <Label styleClass="destination-name" text="Hammamet" />
                                    <Label styleClass="destination-location" text="📍 Cap Bon" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="15">
                                    <Label styleClass="destination-meta" text="🏨 32 hébergements" />
