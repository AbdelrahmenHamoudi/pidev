                                </HBox>
                                <FlowPane hgap="8" vgap="8">
                                    <Label styleClass="destination-badge" text="Plages" />
                                    <Label styleClass="destination-badge" text="Médina" />
                                    <Label styleClass="destination-badge" text="Golf" />
                                </FlowPane>
                            </VBox>
                        </VBox>

                        <!-- Sousse -->
                        <VBox prefWidth="280" styleClass="destination-card" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <StackPane prefHeight="160" styleClass="destination-image-sousse">
                                <Region styleClass="destination-overlay" />
                                <Label styleClass="destination-rating" text="★ 4.7" />
                                <Label styleClass="destination-price" text="Dès 100DT/nuit" />
