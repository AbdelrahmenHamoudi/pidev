<!-- CORRECTION: Version JavaFX 22 au lieu de 25 -->

<BorderPane prefHeight="900" prefWidth="1400" stylesheets="@homeClient.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.Controllers.user.client.homeClientController">

    <!-- ============ BACKGROUND GRADIENT ============ -->
    <background>
        <Background>
            <fills>
                <BackgroundFill fill="linear-gradient(from 0% 0% to 100% 100%, #FEF9F0, #FFF5EB, #FEF2E6)" />
            </fills>
        </Background>
    </background>

    <!-- ============ TOP NAVIGATION BAR ============ -->
    <top>
        <VBox styleClass="nav-container">
            <!-- Main Navigation -->
            <HBox alignment="CENTER_LEFT" spacing="30" styleClass="nav-bar">
                <padding>
                    <Insets bottom="15" left="40" right="40" top="15" />
                </padding>

                <!-- Logo RE7LA avec nom visible -->
                <HBox alignment="CENTER" onMouseClicked="#handleLogoClick" spacing="12" styleClass="nav-logo">
                    <StackPane styleClass="nav-logo-bg">
                        <Circle radius="28" styleClass="nav-logo-circle" />
                        <ImageView fitHeight="40" fitWidth="40" preserveRatio="true">
                            <Image url="@../image/logo.png" />
                        </ImageView>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT">
                        <Label styleClass="nav-logo-text" text="RE7LA" />
                        <Label styleClass="nav-logo-subtext" text="Voyage en Tunisie" />
                    </VBox>
                    <Label styleClass="nav-logo-tunisia" text="🇹🇳" />
                </HBox>

                <!-- Navigation Links -->
                <HBox spacing="20" styleClass="nav-links">
                    <Button styleClass="nav-link-active" text="Accueil" />
                    <Button onAction="#handelhebergement" styleClass="nav-link" text="Hébergements" />
                    <Button styleClass="nav-link" text="Activités" />
                    <Button styleClass="nav-link" text="Trajets" />
                    <Button styleClass="nav-link" text="Promotions" />
                    <Button styleClass="nav-link" text="Communauté" />
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Search Bar -->
                <HBox spacing="8" styleClass="nav-search">
                    <TextField promptText="Où voulez-vous aller ?" styleClass="nav-search-field" />
                    <Button styleClass="nav-search-btn" text="🔍" />
                </HBox>

                <!-- User Menu avec image dynamique -->
                <HBox onMouseClicked="#handleUserMenuClick" spacing="20" styleClass="nav-user">
                    <Button styleClass="nav-notif-btn" text="🔔" />
                    <StackPane styleClass="nav-avatar">
                        <Circle fill="linear-gradient(to bottom, #1ABC9C, #16a085)" radius="24" />
                        <!-- Image de l'utilisateur connecté (sera mise à jour dynamiquement) -->
                        <ImageView fx:id="userAvatarImage" fitHeight="42" fitWidth="42" styleClass="nav-avatar-img">
                            <Image url="https://i.pravatar.cc/150?u=user" />
                        </ImageView>
                        <Circle fill="#2ECC71" radius="7" translateX="14" translateY="14" />
                    </StackPane>
                    <VBox alignment="CENTER_LEFT">
                        <!-- Nom de l'utilisateur connecté (sera mis à jour dynamiquement) -->
                        <Label fx:id="userNameLabel" styleClass="nav-user-name" text="Ahmed Ben Ali" />
                        <Label fx:id="userPointsLabel" styleClass="nav-user-points" text="🏆 1250 points" />
                    </VBox>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- ============ CENTER CONTENT ============ -->
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll">
            <VBox alignment="TOP_CENTER" spacing="50" styleClass="home-content">
                <padding>
                    <Insets bottom="50" left="50" right="50" top="30" />
                </padding>

                <!-- ===== HERO SECTION ===== -->
                <StackPane prefHeight="400" styleClass="hero-section">
                    <Region styleClass="hero-overlay" />
                    <VBox alignment="CENTER" spacing="25" styleClass="hero-content">
                        <Text styleClass="hero-title" text="Voyagez autrement en Tunisie">
                            <font>
                                <Font name="System Bold" size="52" />
                            </font>
                        </Text>
                        <Text styleClass="hero-subtitle" text="Découvrez des expériences uniques, des hébergements de charme et des activités authentiques">
                            <font>
                                <Font size="20" />
                            </font>
                        </Text>

                        <!-- Quick Search Card -->
                        <HBox alignment="CENTER" spacing="15" styleClass="hero-search-card">
                            <VBox spacing="5">
                                <Label styleClass="search-label" text="📍 Destination" />
                                <TextField promptText="Tunis, Sousse, Djerba..." styleClass="hero-search-field" />
                            </VBox>
                            <VBox spacing="5">
                                <Label styleClass="search-label" text="📅 Dates" />
                                <HBox spacing="8">
                                    <DatePicker promptText="Arrivée" styleClass="hero-datepicker" />
                                    <DatePicker promptText="Départ" styleClass="hero-datepicker" />
                                </HBox>
                            </VBox>
                            <VBox spacing="5">
                                <Label styleClass="search-label" text="👥 Voyageurs" />
                                <ComboBox promptText="2 adultes" styleClass="hero-combo" />
                            </VBox>
                            <Button prefHeight="48" prefWidth="160" styleClass="hero-search-btn" text="🔍 Rechercher" />
                        </HBox>

                        <!-- Stats Badge -->
                        <HBox alignment="CENTER" spacing="30" styleClass="hero-stats">
                            <VBox alignment="CENTER" spacing="5">
                                <Label styleClass="stat-number" text="500+" />
                                <Label styleClass="stat-label" text="Hébergements" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="5">
                                <Label styleClass="stat-number" text="300+" />
                                <Label styleClass="stat-label" text="Activités" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="5">
                                <Label styleClass="stat-number" text="15k+" />
                                <Label styleClass="stat-label" text="Voyageurs" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="5">
                                <Label styleClass="stat-number" text="4.9" />
                                <Label styleClass="stat-label" text="Note ★" />
                            </VBox>
                        </HBox>
                    </VBox>
                </StackPane>

                <!-- ===== SECTION 1: DESTINATIONS POPULAIRES ===== -->
