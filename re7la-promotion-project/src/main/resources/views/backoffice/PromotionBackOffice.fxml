<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0"
            stylesheets="@../../css/re7la-styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.backoffice.PromotionBackOfficeController">

    <!-- ═══════════════════════════════════════════ -->
    <!-- SIDEBAR                                     -->
    <!-- ═══════════════════════════════════════════ -->
    <VBox fx:id="sidebar" prefWidth="260.0" spacing="10.0" styleClass="sidebar"
          AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">

        <VBox alignment="CENTER" spacing="15.0">
            <VBox.margin><Insets top="25.0"/></VBox.margin>
            <ImageView fitHeight="150.0" fitWidth="150.0" preserveRatio="true">
                <image><Image url="@../../images/logo.png"/></image>
            </ImageView>
        </VBox>

        <Label styleClass="sidebar-title" text="Tableau de bord">
            <VBox.margin><Insets bottom="30.0" left="25.0"/></VBox.margin>
        </Label>

        <Button fx:id="btnGestionUtilisateurs" alignment="BASELINE_LEFT" maxWidth="Infinity"
                mnemonicParsing="false" onAction="#handleShowUsers"
                styleClass="sidebar-button" text="👥   Gestion Utilisateurs"/>
        <Button fx:id="btnComptesBancaires" alignment="BASELINE_LEFT" maxWidth="Infinity"
                mnemonicParsing="false" onAction="#handleShowAccounts"
                styleClass="sidebar-button" text="🏨   Gestion des Hébergements"/>
        <Button fx:id="btnTransactions" alignment="BASELINE_LEFT" maxWidth="Infinity"
                mnemonicParsing="false" onAction="#handleShowTransactions"
                styleClass="sidebar-button" text="🎯   Gestion des Activités"/>
        <Button fx:id="btnCredits" alignment="BASELINE_LEFT" maxWidth="Infinity"
                mnemonicParsing="false" onAction="#handleShowCredits"
                styleClass="sidebar-button" text="🚗   Gestion des Trajets"/>
        <Button fx:id="btnCashback" alignment="BASELINE_LEFT" maxWidth="Infinity"
                mnemonicParsing="false" onAction="#handleShowCashback"
                styleClass="sidebar-button" text="🎁   Gestion des Promotions"/>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox spacing="5.0">
            <VBox.margin><Insets bottom="20.0"/></VBox.margin>
            <Label style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-padding: 0 0 0 20;" text="SYSTÈME"/>
            <Button fx:id="btnParametres" alignment="BASELINE_LEFT" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleShowSettings"
                    styleClass="sidebar-button" text="⚙️   Paramètres"/>
            <Button fx:id="btnDeconnexion" alignment="BASELINE_LEFT" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleLogout"
                    styleClass="sidebar-button" text="🚪   Déconnexion"/>
        </VBox>
    </VBox>

    <!-- ═══════════════════════════════════════════ -->
    <!-- MAIN CONTENT                                -->
    <!-- ═══════════════════════════════════════════ -->
    <StackPane fx:id="mainContentStack"
               AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="260.0"
               AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <!-- VIEW PROMOTION -->
        <ScrollPane fx:id="viewPromotion" fitToWidth="true" styleClass="main-scroll-pane">
            <VBox spacing="20.0" styleClass="content-area">

                <!-- ══ HEADER avec bouton stats à droite du nom Admin ══ -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <VBox>
                        <Label styleClass="header-label" text="Gestion des Promotions"/>
                        <Label styleClass="header-subtitle" text="Créez et gérez vos promotions et packs"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Search box -->
                    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="search-box">
                        <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0"/></padding>
                        <Label text="🔍" textFill="#94a3b8"/>
                        <TextField promptText="Rechercher..." styleClass="search-field"/>
                    </HBox>

                    <!-- ⭐ BOUTON STATISTIQUES - juste avant le profil Admin -->
                    <Button fx:id="btnStatistiques"
                            mnemonicParsing="false"
                            onAction="#handleShowStatistiques"
                            text="📊  Statistiques"
                            style="-fx-background-color: #2C3E50;
                                   -fx-text-fill: white;
                                   -fx-font-weight: 700;
                                   -fx-font-size: 13px;
                                   -fx-padding: 10 18;
                                   -fx-background-radius: 20;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(44,62,80,0.3), 6, 0, 0, 2);"/>

                    <!-- Profil Admin chip -->
                    <HBox alignment="CENTER" spacing="10.0"
                          style="-fx-background-color: white; -fx-background-radius: 30;
                                 -fx-padding: 5 15 5 5;
                                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);">
                        <Circle fill="#e2e8f0" radius="16.0" stroke="WHITE" strokeType="INSIDE"/>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155; -fx-font-size: 13px;" text="Admin"/>
                    </HBox>
                </HBox>

                <!-- STATS ROW -->
                <HBox spacing="15.0">
                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-hebergement" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 24px;" text="🎁"/>
                        <VBox>
                            <Label styleClass="stat-title" text="Total Promotions"/>
                            <Label fx:id="statTotalPromo" styleClass="stat-value" text="0"/>
                        </VBox>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-reservations" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 24px;" text="📦"/>
                        <VBox>
                            <Label styleClass="stat-title" text="Packs Promo"/>
                            <Label fx:id="statPacksPromo" styleClass="stat-value" text="0"/>
                        </VBox>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-disponibles" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 24px;" text="✅"/>
                        <VBox>
                            <Label styleClass="stat-title" text="Actives"/>
                            <Label fx:id="statActivesPromo" styleClass="stat-value" text="0"/>
                        </VBox>
                    </HBox>
                </HBox>

                <!-- MAIN (form + table) -->
                <HBox spacing="20.0">

                    <!-- FORM CARD -->
                    <VBox spacing="20.0" styleClass="card" HBox.hgrow="SOMETIMES" prefWidth="400">
                        <Label styleClass="card-title" text="➕ Créer / Modifier une Promotion"/>
                        <VBox spacing="15.0">
                            <VBox spacing="6.0">
                                <Label styleClass="form-label" text="Nom de la promotion *"/>
                                <TextField fx:id="txtNom" promptText="Ex: Été 2025, Black Friday..." styleClass="text-field"/>
                            </VBox>
                            <VBox spacing="6.0">
                                <Label styleClass="form-label" text="Description *"/>
                                <TextArea fx:id="txtDescription" promptText="Décrivez la promotion..." styleClass="text-area"/>
                            </VBox>
                            <GridPane hgap="10.0" vgap="10.0">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="33"/>
                                    <ColumnConstraints percentWidth="33"/>
                                    <ColumnConstraints percentWidth="34"/>
                                </columnConstraints>
                                <rowConstraints><RowConstraints/></rowConstraints>
                                <VBox spacing="6.0" GridPane.columnIndex="0">
                                    <Label styleClass="form-label" text="Pourcentage (%)"/>
                                    <TextField fx:id="txtPourcentage" promptText="Ex: 20" styleClass="text-field"/>
                                </VBox>
                                <VBox spacing="6.0" GridPane.columnIndex="1">
                                    <Label styleClass="form-label" text="Réduction Fixe (TND)"/>
                                    <TextField fx:id="txtFixe" promptText="Ex: 150" styleClass="text-field"/>
                                </VBox>
                                <VBox spacing="6.0" GridPane.columnIndex="2">
                                    <Label styleClass="form-label" text="Prix/Jour (TND) *"/>
                                    <TextField fx:id="txtPrixParJour" promptText="Ex: 80" styleClass="text-field"/>
                                </VBox>
                            </GridPane>
                            <GridPane hgap="10.0" vgap="10.0">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50"/>
                                    <ColumnConstraints percentWidth="50"/>
                                </columnConstraints>
                                <rowConstraints><RowConstraints/></rowConstraints>
                                <VBox spacing="6.0" GridPane.columnIndex="0">
                                    <Label styleClass="form-label" text="Date Début *"/>
                                    <DatePicker fx:id="dateDebut" styleClass="text-field"/>
                                </VBox>
                                <VBox spacing="6.0" GridPane.columnIndex="1">
                                    <Label styleClass="form-label" text="Date Fin *"/>
                                    <DatePicker fx:id="dateFin" styleClass="text-field"/>
                                </VBox>
                            </GridPane>
                            <VBox spacing="6.0">
                                <Label styleClass="form-label" text="Type de Promotion"/>
                                <CheckBox fx:id="chkPack" style="-fx-padding: 8 0 0 0;"
                                          text="Pack (combinaison de plusieurs offres)"/>
                            </VBox>
                            <VBox spacing="10.0"
                                  style="-fx-border-color: #E2E8F0; -fx-border-radius: 12;
                                         -fx-padding: 15; -fx-background-color: #F9FAFB;
                                         -fx-background-radius: 12;">
                                <Label styleClass="form-label" text="🎯 Appliquer sur des offres"/>
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <Label text="Type d'offre:" style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                                    <ComboBox fx:id="comboTypeOffre" promptText="Choisir..." prefWidth="200"/>
                                </HBox>
                                <TableView fx:id="tableOffres" prefHeight="150">
                                    <columns>
                                        <TableColumn fx:id="colOffreId" prefWidth="50" text="ID"/>
                                        <TableColumn fx:id="colOffreNom" prefWidth="150" text="Nom"/>
                                        <TableColumn fx:id="colOffreDetails" prefWidth="150" text="Détails"/>
                                    </columns>
                                </TableView>
                                <Button fx:id="btnAjouterOffre" onAction="#ajouterOffreAPromotion"
                                        styleClass="secondary-button"
                                        text="➕ Ajouter cette offre" maxWidth="Infinity"/>
                            </VBox>
                        </VBox>
                        <VBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                            <Button fx:id="btnAjouter" maxWidth="Infinity" mnemonicParsing="false"
                                    onAction="#addOrUpdate" prefHeight="45.0"
                                    styleClass="action-button" text="💾   Enregistrer la promotion"/>
                            <HBox spacing="10.0">
                                <Button fx:id="btnSupprimer" maxWidth="Infinity" mnemonicParsing="false"
                                        onAction="#deletePromotion" prefHeight="40.0"
                                        styleClass="delete-button" text="🗑️ Supprimer" HBox.hgrow="ALWAYS"/>
                                <Button maxWidth="Infinity" mnemonicParsing="false"
                                        onAction="#handleCancel" prefHeight="40.0"
                                        styleClass="secondary-button" text="❌ Annuler" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- TABLE PROMOTIONS -->
                    <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT">
                            <Label styleClass="card-title" text="📋 Liste des Promotions"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <HBox spacing="8.0">
                                <Button mnemonicParsing="false" styleClass="secondary-button" text="📊 Export"/>
                                <Button mnemonicParsing="false" styleClass="secondary-button" text="📄 PDF"/>
                            </HBox>
                        </HBox>
                        <TableView fx:id="tablePromotion" prefHeight="500.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="40" text="ID"/>
                                <TableColumn fx:id="colNom" prefWidth="120" text="Nom"/>
                                <TableColumn fx:id="colDescription" prefWidth="150" text="Description"/>
                                <TableColumn fx:id="colPourcentage" prefWidth="80" text="Pourcent"/>
                                <TableColumn fx:id="colFixe" prefWidth="80" text="Fixe (TND)"/>
                                <TableColumn fx:id="colPrixParJour" prefWidth="90" text="Prix/Jour"/>
                                <TableColumn fx:id="colDateDebut" prefWidth="100" text="Début"/>
                                <TableColumn fx:id="colDateFin" prefWidth="100" text="Fin"/>
                                <TableColumn fx:id="colType" prefWidth="90" text="Type"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>

                </HBox>
            </VBox>
        </ScrollPane>

        <!-- VIEW EMPTY -->
        <VBox fx:id="viewEmpty" alignment="CENTER"
              style="-fx-background-color: #F9FAFB;" visible="false">
            <Label style="-fx-font-size: 50px;" text="🚧"/>
            <Label style="-fx-font-size: 20px; -fx-text-fill: #94a3b8; -fx-font-weight: bold;"
                   text="Interface en cours de développement"/>
            <Label style="-fx-font-size: 14px; -fx-text-fill: #cbd5e1;"
                   text="Cette fonctionnalité sera bientôt disponible."/>
        </VBox>

    </StackPane>
</AnchorPane>
