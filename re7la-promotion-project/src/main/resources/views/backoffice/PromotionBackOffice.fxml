<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="760.0" prefWidth="1200.0"
            stylesheets="@../../css/re7la-styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.backoffice.PromotionBackOfficeController">

    <!-- ═══════════════ SIDEBAR ═══════════════ -->
    <VBox prefWidth="260.0" spacing="10.0" styleClass="sidebar"
          AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">

        <VBox alignment="CENTER"><VBox.margin><Insets top="25.0"/></VBox.margin>
            <ImageView fitHeight="140.0" fitWidth="140.0" preserveRatio="true">
                <image><Image url="@../../images/logo.png"/></image>
            </ImageView>
        </VBox>

        <Label styleClass="sidebar-title" text="Tableau de bord">
            <VBox.margin><Insets bottom="25.0" left="25.0"/></VBox.margin>
        </Label>

        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                onAction="#handleShowUsers" styleClass="sidebar-button" text="👥   Gestion Utilisateurs"/>
        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                onAction="#handleShowAccounts" styleClass="sidebar-button" text="🏨   Hébergements"/>
        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                onAction="#handleShowTransactions" styleClass="sidebar-button" text="🎯   Activités"/>
        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                onAction="#handleShowCredits" styleClass="sidebar-button" text="🚗   Trajets"/>
        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false"
                onAction="#handleShowCashback" styleClass="sidebar-button" text="🎁   Promotions"/>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox spacing="5.0"><VBox.margin><Insets bottom="20.0"/></VBox.margin>
            <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 10px; -fx-padding: 0 0 0 22; -fx-font-weight: 700;" text="SYSTÈME"/>
            <Button fx:id="btnParametres" alignment="BASELINE_LEFT" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleShowSettings" styleClass="sidebar-button" text="⚙️   Paramètres"/>
            <Button fx:id="btnDeconnexion" alignment="BASELINE_LEFT" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-button" text="🚪   Déconnexion"/>
        </VBox>
    </VBox>

    <!-- ═══════════════ MAIN ═══════════════ -->
    <StackPane fx:id="mainContentStack"
               AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="260.0"
               AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <!-- ══ VIEW PROMOTION ══ -->
        <ScrollPane fx:id="viewPromotion" fitToWidth="true" styleClass="main-scroll-pane">
            <VBox spacing="18.0" styleClass="content-area">

                <!-- TOP HEADER -->
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <VBox>
                        <Label styleClass="header-label" text="Gestion des Promotions"/>
                        <Label styleClass="header-subtitle" text="Créez, gérez et suivez vos promotions"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Search bar -->
                    <HBox alignment="CENTER_LEFT" spacing="8.0"
                          style="-fx-background-color: white; -fx-background-radius: 25;
                                 -fx-padding: 8 16; -fx-border-color: #E2E8F0;
                                 -fx-border-radius: 25; -fx-border-width: 1;">
                        <Label text="🔍" style="-fx-text-fill: #94A3B8;"/>
                        <TextField fx:id="searchPromoField" promptText="Rechercher une promotion..."
                                   style="-fx-background-color: transparent; -fx-border-width: 0;
                                          -fx-font-size: 13px; -fx-pref-width: 200;"/>
                    </HBox>

                    <!-- Bouton Statistiques -->
                    <Button fx:id="btnStatistiques" mnemonicParsing="false"
                            onAction="#handleShowStatistiques" text="📊  Statistiques"
                            style="-fx-background-color: #2C3E50; -fx-text-fill: white;
                                   -fx-font-weight: 700; -fx-font-size: 13px;
                                   -fx-padding: 10 18; -fx-background-radius: 20; -fx-cursor: hand;"/>

                    <!-- Admin chip -->
                    <HBox alignment="CENTER" spacing="10.0"
                          style="-fx-background-color: white; -fx-background-radius: 30;
                                 -fx-padding: 5 15 5 8;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 1);">
                        <Circle fill="#F39C12" radius="14.0"/>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #334155; -fx-font-size: 13px;" text="Admin"/>
                    </HBox>
                </HBox>

                <!-- STATS CARDS -->
                <HBox spacing="15.0">
                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-hebergement" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 22px;" text="🎁"/>
                        <VBox><Label styleClass="stat-title" text="Total Promotions"/><Label fx:id="statTotalPromo" styleClass="stat-value" text="0"/></VBox>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-reservations" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 22px;" text="📦"/>
                        <VBox><Label styleClass="stat-title" text="Packs"/><Label fx:id="statPacksPromo" styleClass="stat-value" text="0"/></VBox>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="stat-card-disponibles" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 22px;" text="✅"/>
                        <VBox><Label styleClass="stat-title" text="Actives"/><Label fx:id="statActivesPromo" styleClass="stat-value" text="0"/></VBox>
                    </HBox>
                </HBox>

                <!-- CONTENU PRINCIPAL : Form gauche + Cards droite -->
                <HBox spacing="20.0" VBox.vgrow="ALWAYS">

                    <!-- ── FORMULAIRE ── -->
                    <VBox spacing="14.0" styleClass="card"
                          prefWidth="390" minWidth="360" maxWidth="400">

                        <Label styleClass="card-title" text="➕  Nouvelle Promotion"/>

                        <VBox spacing="5.0">
                            <Label styleClass="form-label" text="Nom *"/>
                            <TextField fx:id="txtNom" promptText="Ex: Été 2025" styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="5.0">
                            <Label styleClass="form-label" text="Description *"/>
                            <TextArea fx:id="txtDescription" promptText="Décrivez la promotion…" styleClass="text-area" prefRowCount="3"/>
                        </VBox>

                        <GridPane hgap="10.0" vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33"/>
                                <ColumnConstraints percentWidth="33"/>
                                <ColumnConstraints percentWidth="34"/>
                            </columnConstraints>
                            <rowConstraints><RowConstraints/></rowConstraints>
                            <VBox spacing="4.0" GridPane.columnIndex="0">
                                <Label styleClass="form-label" text=" Réduct."/>
                                <TextField fx:id="txtPourcentage" promptText="20" styleClass="text-field"/>
                            </VBox>
                            <VBox spacing="4.0" GridPane.columnIndex="1">
                                <Label styleClass="form-label" text="Fixe (TND)"/>
                                <TextField fx:id="txtFixe" promptText="150" styleClass="text-field"/>
                            </VBox>
                            <VBox spacing="4.0" GridPane.columnIndex="2">
                                <Label styleClass="form-label" text="Prix/Jour *"/>
                                <TextField fx:id="txtPrixParJour" promptText="80" styleClass="text-field"/>
                            </VBox>
                        </GridPane>

                        <GridPane hgap="10.0" vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>
                            <rowConstraints><RowConstraints/></rowConstraints>
                            <VBox spacing="4.0" GridPane.columnIndex="0">
                                <Label styleClass="form-label" text="Date Début *"/>
                                <DatePicker fx:id="dateDebut"/>
                            </VBox>
                            <VBox spacing="4.0" GridPane.columnIndex="1">
                                <Label styleClass="form-label" text="Date Fin *"/>
                                <DatePicker fx:id="dateFin"/>
                            </VBox>
                        </GridPane>

                        <!-- Options -->
                        <VBox spacing="8.0" style="-fx-background-color: #F9FAFB; -fx-padding: 12;
                                                    -fx-background-radius: 10; -fx-border-color: #E2E8F0;
                                                    -fx-border-radius: 10; -fx-border-width: 1;">
                            <Label style="-fx-font-size: 11px; -fx-font-weight: 700;
                                          -fx-text-fill: #64748B;" text="OPTIONS"/>
                            <CheckBox fx:id="chkPack" text="📦  Pack (combinaison d'offres)"/>
                            <CheckBox fx:id="chkLocked" text="🔒  Verrouillée (code requis)"/>
                        </VBox>

                        <!-- Offres -->
                        <VBox spacing="8.0" style="-fx-background-color: #F9FAFB; -fx-padding: 12;
                                                    -fx-background-radius: 10; -fx-border-color: #E2E8F0;
                                                    -fx-border-radius: 10; -fx-border-width: 1;">
                            <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #64748B;" text="OFFRES ASSOCIÉES"/>
                            <ComboBox fx:id="comboTypeOffre" promptText="Type d'offre…" maxWidth="Infinity"/>
                            <TableView fx:id="tableOffres" prefHeight="110">
                                <columns>
                                    <TableColumn fx:id="colOffreId" prefWidth="40" text="ID"/>
                                    <TableColumn fx:id="colOffreNom" prefWidth="120" text="Nom"/>
                                    <TableColumn fx:id="colOffreDetails" prefWidth="120" text="Détails"/>
                                </columns>
                            </TableView>
                            <Button onAction="#ajouterOffreAPromotion" maxWidth="Infinity"
                                    styleClass="secondary-button" text="➕  Ajouter l'offre sélectionnée"/>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS"/>

                        <!-- Boutons action -->
                        <VBox spacing="8.0">
                            <Button fx:id="btnAjouter" maxWidth="Infinity" mnemonicParsing="false"
                                    onAction="#addOrUpdate" prefHeight="44.0"
                                    styleClass="action-button" text="💾   Enregistrer la promotion"/>
                            <HBox spacing="8.0">
                                <Button fx:id="btnSupprimer" maxWidth="Infinity" mnemonicParsing="false"
                                        onAction="#deletePromotion" styleClass="delete-button"
                                        text="🗑️  Supprimer" HBox.hgrow="ALWAYS"/>
                                <Button maxWidth="Infinity" mnemonicParsing="false"
                                        onAction="#handleCancel" styleClass="secondary-button"
                                        text="❌  Annuler" HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <!-- PDF button -->
                            <Button maxWidth="Infinity" mnemonicParsing="false"
                                    onAction="#handleExportPDF" prefHeight="40.0"
                                    text="📄  Exporter en PDF"
                                    style="-fx-background-color: #1ABC9C; -fx-text-fill: white;
                                           -fx-font-weight: 700; -fx-font-size: 13px;
                                           -fx-background-radius: 12; -fx-cursor: hand;
                                           -fx-effect: dropshadow(gaussian, rgba(26,188,156,0.3), 6, 0, 0, 2);"/>
                        </VBox>
                    </VBox>

                    <!-- ── LISTE CARDS PROMOTIONS ── -->
                    <VBox HBox.hgrow="ALWAYS" spacing="14.0">
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <Label style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #2C3E50;"
                                   text="📋  Mes Promotions"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"
                                   text="Cliquez sur une card pour la modifier · Sélectionnez avant d'exporter en PDF"/>
                        </HBox>

                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;">
                            <GridPane fx:id="promoCardsGrid" hgap="16" vgap="16" />
                        </ScrollPane>
                    </VBox>

                </HBox>
            </VBox>
        </ScrollPane>

        <!-- ══ VIEW EMPTY ══ -->
        <VBox fx:id="viewEmpty" alignment="CENTER"
              style="-fx-background-color: #F9FAFB;" visible="false">
            <Label style="-fx-font-size: 50px;" text="🚧"/>
            <Label style="-fx-font-size: 20px; -fx-text-fill: #94a3b8; -fx-font-weight: bold;"
                   text="Interface en cours de développement"/>
        </VBox>

    </StackPane>
</AnchorPane>
