<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.embed.swing.SwingNode?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controllers.backoffice.StatistiquesReservationsController"
      spacing="0"
      stylesheets="@../../css/re7la-styles.css"
      style="-fx-background-color: #eef2f6;">

    <!-- ═══ HEADER ═══ -->
    <HBox alignment="CENTER_LEFT" spacing="15"
          style="-fx-background-color: white;
                 -fx-padding: 18 30 18 30;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                 -fx-border-color: transparent transparent #F7DC6F transparent;
                 -fx-border-width: 0 0 3 0;">

        <Button text="← Retour" onAction="#handleRetour"
                style="-fx-background-color: #eef2f6;
                       -fx-text-fill: #2C3E50;
                       -fx-font-weight: 700;
                       -fx-font-size: 13px;
                       -fx-padding: 9 18;
                       -fx-background-radius: 20;
                       -fx-cursor: hand;
                       -fx-border-color: #E2E8F0;
                       -fx-border-radius: 20;
                       -fx-border-width: 1;"/>

        <VBox spacing="2">
            <Label text="Statistiques des Promotions"
                   style="-fx-font-size: 22px; -fx-font-weight: 800; -fx-text-fill: #2C3E50;"/>
            <Label text="Analyse des performances · Promotions RE7LA"
                   style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <HBox spacing="15" alignment="CENTER">
            <VBox alignment="CENTER" spacing="2"
                  style="-fx-background-color: #FFF9E6;
                         -fx-padding: 10 20;
                         -fx-background-radius: 14;
                         -fx-border-color: #F7DC6F;
                         -fx-border-radius: 14;
                         -fx-border-width: 1;">
                <Label fx:id="kpiTotalLabel" text="—"
                       style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #2C3E50;"/>
                <Label text="Promotions"
                       style="-fx-font-size: 11px; -fx-text-fill: #64748B; -fx-font-weight: 600;"/>
            </VBox>
            <VBox alignment="CENTER" spacing="2"
                  style="-fx-background-color: #E6F5F1;
                         -fx-padding: 10 20;
                         -fx-background-radius: 14;
                         -fx-border-color: #1ABC9C;
                         -fx-border-radius: 14;
                         -fx-border-width: 1;">
                <Label fx:id="kpiReservationsLabel" text="—"
                       style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #2C3E50;"/>
                <Label text="Réservations"
                       style="-fx-font-size: 11px; -fx-text-fill: #64748B; -fx-font-weight: 600;"/>
            </VBox>
            <VBox alignment="CENTER" spacing="2"
                  style="-fx-background-color: #EEF2FF;
                         -fx-padding: 10 20;
                         -fx-background-radius: 14;
                         -fx-border-color: #6366F1;
                         -fx-border-radius: 14;
                         -fx-border-width: 1;">
                <Label fx:id="kpiUsersLabel" text="—"
                       style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #2C3E50;"/>
                <Label text="Utilisateurs"
                       style="-fx-font-size: 11px; -fx-text-fill: #64748B; -fx-font-weight: 600;"/>
            </VBox>
        </HBox>

        <Button text="↺  Actualiser" onAction="#handleRefresh"
                style="-fx-background-color: #F39C12;
                       -fx-text-fill: white;
                       -fx-font-weight: 700;
                       -fx-font-size: 13px;
                       -fx-padding: 9 20;
                       -fx-background-radius: 20;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(243,156,18,0.35), 8, 0, 0, 2);"/>
    </HBox>

    <!-- ═══ CONTENU SCROLLABLE ═══ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;">
        <VBox spacing="20" style="-fx-padding: 25 30 30 30;">

            <!-- LIGNE 1 : Top Promotions pleine largeur -->
            <VBox style="-fx-background-color: white;
                         -fx-background-radius: 18;
                         -fx-padding: 20 22 16 22;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);
                         -fx-border-color: #F7DC6F;
                         -fx-border-radius: 18;
                         -fx-border-width: 0 0 0 4;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🏆" style="-fx-font-size: 16px;"/>
                    <Label text="Top 10 Promotions les Plus Réservées"
                           style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #2C3E50;"/>
                </HBox>
                <Label text="Classement par nombre de réservations générées"
                       style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-padding: 2 0 10 0;"/>
                <StackPane fx:id="chartTopPromos" prefHeight="260"/>
            </VBox>

            <!-- LIGNE 2 : Users actifs + moins actifs -->
            <HBox spacing="20">
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-padding: 20 22 16 22;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);
                             -fx-border-color: #1ABC9C;
                             -fx-border-radius: 18;
                             -fx-border-width: 0 0 0 4;">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="👤" style="-fx-font-size: 15px;"/>
                        <Label text="Utilisateurs les Plus Actifs"
                               style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #2C3E50;"/>
                    </HBox>
                    <Label text="Top 10 · avec promotions"
                           style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-padding: 2 0 10 0;"/>
                    <StackPane fx:id="chartTopUsers" prefHeight="250"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-padding: 20 22 16 22;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);
                             -fx-border-color: #2C3E50;
                             -fx-border-radius: 18;
                             -fx-border-width: 0 0 0 4;">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="💤" style="-fx-font-size: 15px;"/>
                        <Label text="Utilisateurs les Moins Actifs"
                               style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #2C3E50;"/>
                    </HBox>
                    <Label text="Top 10 · moins de réservations"
                           style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-padding: 2 0 10 0;"/>
                    <StackPane fx:id="chartLeastUsers" prefHeight="250"/>
                </VBox>
            </HBox>

            <!-- LIGNE 3 : Type promo + Combos -->
            <HBox spacing="20">
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-padding: 20 22 16 22;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);
                             -fx-border-color: #F39C12;
                             -fx-border-radius: 18;
                             -fx-border-width: 0 0 0 4;">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="📊" style="-fx-font-size: 15px;"/>
                        <Label text="Répartition par Type"
                               style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #2C3E50;"/>
                    </HBox>
                    <Label text="Individuelles vs Packs"
                           style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-padding: 2 0 10 0;"/>
                    <StackPane fx:id="chartTypePromo" prefHeight="280"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-padding: 20 22 16 22;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);
                             -fx-border-color: #F7DC6F;
                             -fx-border-radius: 18;
                             -fx-border-width: 0 0 0 4;">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="📦" style="-fx-font-size: 15px;"/>
                        <Label text="Compositions de Packs"
                               style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #2C3E50;"/>
                    </HBox>
                    <Label text="Meilleures combinaisons d'offres"
                           style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-padding: 2 0 10 0;"/>
                    <StackPane fx:id="chartCombosPacks" prefHeight="280"/>
                </VBox>
            </HBox>

        </VBox>
    </ScrollPane>

</VBox>
